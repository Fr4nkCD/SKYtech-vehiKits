						</Item>
						<Item class="Script" referent="RBX07C57C1805DF4D81BC170766A5712A19">
							<Properties>
								<ProtectedString name="Source"><![CDATA[task.wait(1)
----- Settings -----
local sound_BasePitch, sound_MaxPitch, sound_Volume = 0.8, 1.2, 1.5
--------------------

local rotors = script.Parent.Parent
local top_Rotor = rotors:WaitForChild("TopRotor"):WaitForChild("Main"):WaitForChild("Motor")
local rotor_Sound = top_Rotor.Parent:WaitForChild("Sound")

top_Rotor:GetPropertyChangedSignal("AngularVelocity"):Connect(function()
	local rotor_RPM = script.Parent:GetAttribute("RPM")
	rotor_Sound.PlaybackSpeed = (sound_BasePitch * math.clamp(top_Rotor.AngularVelocity/(rotor_RPM/20), 0, 1)) + ((sound_MaxPitch - sound_BasePitch) * math.clamp((top_Rotor.AngularVelocity - (rotor_RPM/20))/(rotor_RPM/20), 0, 1))
	rotor_Sound.Volume = (top_Rotor.AngularVelocity/(rotor_RPM/20)) * sound_Volume
end)]]></ProtectedString>
