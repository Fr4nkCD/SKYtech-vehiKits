							<BinaryString name="Tags"></BinaryString>
						</Properties>
						<Item class="Script" referent="RBXD73977ED9A3C43A2B7F3BD2F0BA1DA5E">
							<Properties>
								<ProtectedString name="Source"><![CDATA[task.wait(1)
local rotors = script.Parent.Parent

local topRotor = rotors:WaitForChild("TopRotor")
local tailRotor = rotors:WaitForChild("TailRotor")

local topRotor_Motor = topRotor:WaitForChild("Main"):WaitForChild("Motor")
local tailRotor_Motor = tailRotor:WaitForChild("Main"):WaitForChild("Motor")

local topRotor_motionBlurPart = topRotor:WaitForChild("Parts"):WaitForChild("MotionBlur")
local tailRotor_motionBlurPart = tailRotor:WaitForChild("Parts"):WaitForChild("MotionBlur")

local topRotor_blurParts = {}
for _, part in (topRotor.Parts:GetDescendants()) do
	if part:IsA("BasePart") and part:GetAttribute("CanBlur") then
		table.insert(topRotor_blurParts, part)
	end
end

local tailRotor_blurParts = {}
for _, part in (tailRotor.Parts:GetDescendants()) do
	if part:IsA("BasePart") and part:GetAttribute("CanBlur") then
		table.insert(tailRotor_blurParts, part)
	end
end

topRotor_Motor:GetPropertyChangedSignal("AngularVelocity"):Connect(function()
	local topRotor_motionBlur = math.min(topRotor_Motor.AngularVelocity/50, 1)
	topRotor_motionBlurPart.Decal1.Transparency = 1 - topRotor_motionBlur
	topRotor_motionBlurPart.Decal2.Transparency = 1 - topRotor_motionBlur
	for _, blurPart in (topRotor_blurParts) do
		blurPart.Transparency = topRotor_motionBlur
	end
	----
	local tailRotor_motionBlur = math.min(tailRotor_Motor.AngularVelocity/100, 1)
	tailRotor_motionBlurPart.Decal1.Transparency = 1 - tailRotor_motionBlur
	tailRotor_motionBlurPart.Decal2.Transparency = 1 - tailRotor_motionBlur
	for _, blurPart in (tailRotor_blurParts) do
		blurPart.Transparency = tailRotor_motionBlur
	end
end)]]></ProtectedString>
								<bool name="Disabled">false</bool>
