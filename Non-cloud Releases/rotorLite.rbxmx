							<Item class="Script" referent="RBX22048D6B4E394715A9E137E591807726">
								<Properties>
									<ProtectedString name="Source"><![CDATA[-- A basic weld script
local parent = script.Parent
local anchorPrimaryPart = false

local parts = {}
for _, part in (parent:GetDescendants()) do
	if part:IsA("BasePart") then
		table.insert(parts, part)
	end
end

local primaryPart = parent:IsA("BasePart") and parent or parts[1]

function createWeld(x, y)
	local weld = Instance.new("Weld")
	weld.Part0 = x
	weld.Part1 = y
	weld.C0 = x.CFrame:ToObjectSpace(y.CFrame)
	weld.Parent = x
end

for _, part in (parts) do 
	part.Anchored = true -- Anchor to prevent part shifting
	createWeld(part, primaryPart)
	part.Anchored = false -- Unanchor after welded
end

primaryPart.Anchored = anchorPrimaryPart

-- Clear the table in case of memory leak
table.clear(parts)

script:Destroy()]]></ProtectedString>
