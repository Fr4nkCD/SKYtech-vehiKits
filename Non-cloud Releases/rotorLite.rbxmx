				</Properties>
				<Item class="Folder" referent="RBX5B106C61E67D4741998B7E23E1267CC2">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
						<bool name="DefinesCapabilities">true</bool>
						<string name="Name">Modules</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
					<Item class="ModuleScript" referent="RBX359D970D9B924FD2B96E56D9660A414A">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local module = {}

function module.FindMissingSettings(Settings, Presets)
	-- Find missing settings
	for category, values in pairs(Presets) do
		for name, value in pairs(values) do
			local atrrName = category.."/"..name
			if Settings:GetAttribute(atrrName) == nil then
				value = if typeof(value) == "EnumItem" then value.Name else value
				Settings:SetAttribute(atrrName, value)
			end
		end
	end
end

function module.SyncValue(AtrrName, Value, Folder, ConnectionsTable)
	-- Sync the legacy value with an attribute.

	-- Value Changed
	table.insert(ConnectionsTable, Value:GetPropertyChangedSignal("Value"):Connect(function()
		local newValue = Value.Value
		if newValue ~= Folder:GetAttribute(AtrrName) then
			Folder:SetAttribute(AtrrName, newValue)
		end
	end))

	-- Attribute Changed
	table.insert(ConnectionsTable, Folder:GetAttributeChangedSignal(AtrrName):Connect(function()
		local newValue = Folder:GetAttribute(AtrrName)
		if newValue ~= nil and newValue ~= Value.Value then
			Value.Value = newValue
		end
	end))
end

function module.SyncSettings(Settings, ConnectionsTable)
	-- Sync attributes with legacy values if found.
	for _, category in (Settings:GetChildren()) do
		local categoryName = category.Name:gsub("_", "")

		for _, value in (category:GetChildren()) do
			local valueName = value.Name:gsub("_", "")
			local attrName = categoryName.."/"..valueName
			local attribute = Settings:GetAttribute(attrName)
			
			-- Overwrite the attribute if the legacy value is found.
			Settings:SetAttribute(categoryName.."/"..valueName, value.Value)

			-- Sync attributes and value objects.
			module.SyncValue(attrName, value, Settings, ConnectionsTable)
		end
	end
end

return module
]]></ProtectedString>
							<string name="ScriptGuid">{FF609DA8-B23B-4B1F-93C5-DC82D6FAD0D1}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
							<bool name="DefinesCapabilities">true</bool>
							<string name="Name">LegacySyncing</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX2DC9544A1E4E4746AF7D90EFB09F4497">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local module = {}

local function getBurnPercentages(PowerType)
	-- Get burn percentages based on the aircraft type (fixed wing = throttle, helicopter = collective)
	local isThrottle = PowerType == "Throttle" -- Throttle or Collective
	local idleBurnPercent = if isThrottle then 0.1 else 0.5
	local activeBurnPercent = if isThrottle then 0.9 else 0.5

	return idleBurnPercent, activeBurnPercent
end

function module.ProcessBurn(
	PowerType : string,
	consumptionRate : Configuration,
	Stats_ : Folder,
	deltaTime : number,
	legacyValue : NumberValue
)
	local currentFuel = Stats_:GetAttribute("Fuel") or 100
	local isActive = Stats_:GetAttribute("Active") == true
	
	local idleBurnPercent, activeBurnPercent = getBurnPercentages(PowerType)
	
	if currentFuel > 0 and isActive then
		local idleBurn = if isActive then idleBurnPercent else 0
		local activeBurn = Stats_:GetAttribute(PowerType) * activeBurnPercent
		local burnPerSecond = consumptionRate * (idleBurn + activeBurn) * deltaTime
		
		local newFuel = math.max(0, currentFuel - burnPerSecond)
		Stats_:SetAttribute("Fuel", newFuel)

		if legacyValue then
			-- Sync the legacy value if found.
			legacyValue.Value = newFuel
		end
	end
end

return module
]]></ProtectedString>
							<string name="ScriptGuid">{7AF86AAE-7EB4-4AFC-97B5-DAEDD0A89F4F}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
							<bool name="DefinesCapabilities">true</bool>
							<string name="Name">FuelManagement</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX5E36F6EE2E6749E7871B89DD0F86FC74">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Welder = {}

local function getParts(object, partsTable)
	-- If this folder/part has the ignore signal, STOP searching this entire branch
	if object:FindFirstChild("IgnoreWeld") then 
		return 
	end

	if object:IsA("BasePart") then
		table.insert(partsTable, object)
	end

	-- Recurse into children
	for _, child in ipairs(object:GetChildren()) do
		getParts(child, partsTable)
	end
end

function Welder.Weld(model, primaryPart)
	if not primaryPart then return end

	local weldFolder = primaryPart:FindFirstChild("Welds") or Instance.new("Folder")
	weldFolder.Name = "Welds"
	weldFolder.Parent = primaryPart

	local parts = {}
	getParts(model, parts)

	primaryPart.RootPriority = 10

	-- Anchor to prevent parts falling during welding
	for _, part in (parts) do
		part.Anchored = true
	end

	-- Time-Budgeted Loop (The "Anti-Timeout" Logic)
	local startTime = os.clock()
	local TIME_BUDGET = 0.002 -- 2ms per frame

	for _, part in (parts) do
		-- Safety check to prevent the script from hanging on massive models
		if os.clock() - startTime > TIME_BUDGET then
			task.wait()
			startTime = os.clock()
		end

		if part == primaryPart then continue end

		local weld = Instance.new("Weld")
		weld.Part0 = primaryPart
		weld.Part1 = part
		weld.C0 = primaryPart.CFrame:ToObjectSpace(part.CFrame)
		weld.Parent = weldFolder
	end

	for _, part in ipairs(parts) do
		part.Anchored = false
	end

	parts = nil
end

return Welder]]></ProtectedString>
							<string name="ScriptGuid">{DA1CDFE1-53A3-4770-B092-C6A5497F0B4D}</string>
