								<Item class="LocalScript" referent="RBX1C304E7B736D419F8D6BF5B4B8ED826A">
									<Properties>
										<ProtectedString name="Source"><![CDATA[-- Anti-jump --
local player = game:GetService("Players").LocalPlayer
local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
humanoid.JumpHeight = 0
humanoid.JumpPower = 0
-- Disable on client side just in case someone jumps too quick

script.Parent.Remote:FireServer(false) -- Disable server-side jump
local exiting = false

local panel = script.Parent.Parent
local defaultBarSize = panel.Size
panel.Size = UDim2.new(0, 0, defaultBarSize.Y.Scale, defaultBarSize.Y.Offset)

function exit()
	exiting = true
	panel.Visible = true
	panel:TweenSize(defaultBarSize, "Out", "Linear", 1.25, true)
	while exiting do
		if panel.Size.X.Scale > 0.9 or panel.Size.X.Offset/defaultBarSize.X.Offset > 0.9 then
			script.Parent.Remote:FireServer(true)
			break
		end
		task.wait()
	end
end

function cancel()
	exiting = false
	panel.Visible = false
	panel:TweenSize(UDim2.new(0, 0, defaultBarSize.Y.Scale, defaultBarSize.Y.Offset), "Out", "Linear", 0.1, true)
	panel.Size = UDim2.new(0, 0, defaultBarSize.Y.Scale, defaultBarSize.Y.Offset)
end

local UIS = game:GetService("UserInputService")
UIS.InputBegan:Connect(function(input, proceeded)
	if not proceeded then
		if input.KeyCode == Enum.KeyCode.Space then
			exit()
		end
	end
end)

UIS.InputEnded:Connect(function(input, proceeded)
	if not proceeded then
		if input.KeyCode == Enum.KeyCode.Space then
			cancel()
		end
	end
end)

local mobile_Button = panel.Exit_Button

if UIS:GetLastInputType() == Enum.UserInputType.Touch or UIS:GetLastInputType() == Enum.UserInputType.Gamepad1 then
	mobile_Button.Visible = true
	mobile_Button.Parent = panel.Parent
else
	mobile_Button.Visible = false
	mobile_Button.Parent = panel
end

mobile_Button.MouseButton1Down:Connect(exit)
mobile_Button.MouseButton1Up:Connect(cancel)
mobile_Button.MouseLeave:Connect(cancel)]]></ProtectedString>
