							<Item class="Folder" referent="RBX3F7AC196CC2B4EA995A13B8255BFCA98">
								<Properties>
									<BinaryString name="AttributesSerialize"></BinaryString>
									<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
