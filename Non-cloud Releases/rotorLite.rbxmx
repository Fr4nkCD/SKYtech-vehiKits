					<Item class="ModuleScript" referent="RBX8585A512687240C5A108EE68A42E4F89">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local NetworkManager = {}

function NetworkManager.GetNetworkOwner(rootAssembly : BasePart)
	local isGrounded = rootAssembly:IsGrounded()
	local inWorkspace = rootAssembly:IsDescendantOf(workspace)
	if isGrounded or not inWorkspace then
		return nil
	else
		return rootAssembly:GetNetworkOwner()
	end
end

function NetworkManager.SetNetworkOwner(
	player : Player,
	rootAssembly : BasePart,
	assembly
)
	if assembly then
		-- Set the network owner attribute if the assembly is found in case of it being anchored.
		assembly:SetAttribute("NetworkOwner", if player then player.UserId else nil)
	end
	
	local isGrounded = rootAssembly:IsGrounded()
	if not isGrounded then
		-- Only change if the the assembly is unanchored.
		rootAssembly:SetNetworkOwner(player)
	end
end

function NetworkManager.UpdateNetworkOwner(
	playerValue : ObjectValue,
	rootAssembly : BasePart,
	assembly, 
	isClientControlled : boolean,
	canResetNetwork : boolean
)
	-- Update network owner based on the current player found.
	if not rootAssembly:IsGrounded() and rootAssembly:IsDescendantOf(workspace) then
		local networkOwner = rootAssembly:GetNetworkOwner()
		if not networkOwner then
			if playerValue.Value and isClientControlled then
				rootAssembly:SetNetworkOwner(playerValue.Value)
			else
				if assembly:GetAttribute("NetworkOwner") and canResetNetwork then
					assembly:SetAttribute("NetworkOwner", nil)
				end
			end
		else
			if not assembly:GetAttribute("NetworkOwner") then
				assembly:SetAttribute("NetworkOwner", networkOwner.UserId)
			end
		end
	end
end

return NetworkManager]]></ProtectedString>
