							<Item class="LocalScript" referent="RBXB133758928FC4CD6B42190AA62361CDD">
								<Properties>
									<ProtectedString name="Source"><![CDATA[------------ Gamepad Control Module ------------
local UserInputService = game:GetService("UserInputService")
if UserInputService:GetLastInputType() ~= Enum.UserInputType.Gamepad1 then
	script.Parent:Destroy()
	return
end

local ContextActionService = game:GetService("ContextActionService")
local GamepadService = game:GetService("GamepadService")
local RunService = game:GetService("RunService")
local GuiService = game:GetService("GuiService")

GuiService.AutoSelectGuiEnabled = false

local player = game:GetService("Players").LocalPlayer
local camera = workspace.CurrentCamera

local gui = script.Parent.Parent
local gamepadPanel = script.Parent

local controller = gui.Controller
local aircraft = gui.Aircraft.Value
local Settings = aircraft.Settings

local main = aircraft.Main
local mainPart = main.Main
local Stats_ = main.Stats
local Mods = main.Mods

local landingGear = Mods:FindFirstChild("LandingGear")
local gearRemote = if landingGear then landingGear:FindFirstChild("Remote") else nil

local stateWrapper = aircraft.System
local updateEvent = stateWrapper.Update

local Keybinds = {
	LockCamera = Settings:GetAttribute("FlightControls/Gamepad/LockCamera"),
	Engine = Settings:GetAttribute("FlightControls/Gamepad/Engine"),
	CollectiveUp = Settings:GetAttribute("FlightControls/Gamepad/CollectiveUp"),
	CollectiveDown = Settings:GetAttribute("FlightControls/Gamepad/CollectiveDown"),
	LandingGear = Settings:GetAttribute("FlightControls/Gamepad/LandingGear"),
}

GamepadCameraCycles = {}
for attrName, value in pairs(Settings:GetAttributes()) do
	if attrName:find("GamepadCameraCycles") then
		local index = attrName:gsub("FlightControls/GamepadCameraCycles/", "")
		GamepadCameraCycles[tonumber(index)] = value
	end
end

local lockCamera = false
local gamepadCursor = false
local cursorOrigin = gamepadPanel.Guide_Button

local boundCFrame, boundSize = aircraft:GetBoundingBox() -- Camera disance based on the aircraft size
local camCycle = math.max(#GamepadCameraCycles - 1, 1) -- Start index at the 2nd last

local aircraftSize = boundSize.Magnitude
local cameraDistance = math.max(aircraftSize * GamepadCameraCycles[camCycle], 0.5)
local currentCameraDistance = cameraDistance

task.delay(0.1, function() controller:SetAttribute("Custom_Control", true) end)
controller:SetAttribute("Collective", Stats_:GetAttribute("Collective"))

local collectiveInput = Stats_:GetAttribute("Collective")
local collectiveChange = 0
local yawInput, pitchInput = 0, 0

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	if Keybinds.LockCamera ~= "nil" and input.KeyCode == Enum.KeyCode[Keybinds.LockCamera] then
		if not lockCamera then
			lockCamera = true
			camera.CameraType = Enum.CameraType[Settings:GetAttribute("FlightControls/CameraType")]
		else
			lockCamera = false
			camera.CameraType = Enum.CameraType.Custom
		end


	elseif Keybinds.Engine ~= "nil" and input.KeyCode == Enum.KeyCode[Keybinds.Engine] then
		updateEvent:FireServer("Active")


	elseif input.KeyCode == Enum.KeyCode[Keybinds.CollectiveUp] then
		collectiveChange = 1
	elseif input.KeyCode == Enum.KeyCode[Keybinds.CollectiveDown] then
		collectiveChange = -1
		
		
	elseif input.KeyCode == Enum.KeyCode.ButtonL2 then
		controller:SetAttribute("Roll", 1)
	elseif input.KeyCode == Enum.KeyCode.ButtonR2 then
		controller:SetAttribute("Roll", -1)
		
		
	elseif Keybinds.LandingGear ~= "nil" and gearRemote and input.KeyCode == Enum.KeyCode[Keybinds.LandingGear] then
		gearRemote:FireServer()
	end
end)

UserInputService.InputEnded:Connect(function(input, processed) -- Keys released
	if processed then return end

	if input.KeyCode == Enum.KeyCode[Keybinds.CollectiveUp] or input.KeyCode == Enum.KeyCode[Keybinds.CollectiveDown] then
		collectiveChange = 0


	elseif input.KeyCode == Enum.KeyCode.ButtonL2 or input.KeyCode == Enum.KeyCode.ButtonR2 then
		controller:SetAttribute("Roll", 0)
	end
end)

-----------------------------------------

local function IncreaseCollective(actionName, inputState)
	if inputState == Enum.UserInputState.Begin then
		collectiveChange = 1
	else
		collectiveChange = 0
	end
end

local function ToggleCameraCycles(actionName, inputState)
	if inputState == Enum.UserInputState.Begin then
		camCycle = math.max((camCycle + 1) % (#GamepadCameraCycles + 1), 1)
		cameraDistance = math.max(aircraftSize * GamepadCameraCycles[camCycle], 0.5)
	end
end

local function ToggleGamepadCursor(actionName, inputState)
	if inputState == Enum.UserInputState.End then
		gamepadCursor = not gamepadCursor	
		if gamepadCursor then
			GamepadService:EnableGamepadCursor(cursorOrigin)
		else
			GamepadService:DisableGamepadCursor()
		end
	end
end

if Keybinds.CollectiveUp == "ButtonA" then
	ContextActionService:BindActionAtPriority(
		"Increase Collective",
		IncreaseCollective,
		false,
		3000,
		Enum.KeyCode.ButtonA
	)
end

ContextActionService:BindActionAtPriority(
	"Toggle Camera Cycles",
	ToggleCameraCycles,
	false,
	3000,
	Enum.KeyCode.ButtonR3
)

ContextActionService:BindActionAtPriority(
	"Toggle Gamepad Cursor",
	ToggleGamepadCursor,
	false,
	3000,
	Enum.KeyCode.ButtonSelect
)

-----------------------------------------

-- Guide Panel
local guidePanel = gamepadPanel.Guide
local guideButton = gamepadPanel.Guide_Button

guidePanel.Setup.Enabled = true
guidePanel.Visible = false

guideButton.MouseButton1Click:Connect(function()
	guidePanel.Visible = not guidePanel.Visible
end)

-- Main
local RunFunction = RunService.Heartbeat:Connect(function(dt)
	-- Send inputs to the kit controller attributes.

	if Stats_:GetAttribute("Active") == true then
		collectiveInput = math.clamp(collectiveInput + (collectiveChange * Settings:GetAttribute("FlightControls/CollectiveIncrement") * dt), 0, 1)
		controller:SetAttribute("Collective", collectiveInput)
	else
		collectiveInput = 0
		controller:SetAttribute("Collective", 0)
	end
	
	local gamepadStates = UserInputService:GetGamepadState(Enum.UserInputType.Gamepad1)
	for _, input in (gamepadStates) do
		if input.KeyCode == Enum.KeyCode.Thumbstick1 then
			local position = -input.Position
			yawInput = position.X
			pitchInput = position.Y
		end
	end
	
	if gamepadCursor then
		yawInput, pitchInput = 0, 0
	end
	
	controller:SetAttribute("Yaw", yawInput)
	controller:SetAttribute("Pitch", pitchInput)
	
	local mobileRange = Settings:GetAttribute("FlightControls/MobileRange") or Vector2.new(45, 45)

	if yawInput ~= 0 or pitchInput ~= 0 then
		local position = mainPart.Position
		local _, yawAngle, _ = mainPart.CFrame:ToOrientation()
		local direction = CFrame.Angles(0, yawAngle, 0) * CFrame.Angles(
			math.rad(mobileRange.Y * pitchInput),
			math.rad(mobileRange.X * yawInput),
			0
		)
		controller:SetAttribute("MousePosition", position + (direction.LookVector * 1e6))
	else
		controller:SetAttribute("MousePosition", nil)
	end
	
	-- Camera cycles
	local zoomSentivity = 1 - math.exp(-16 * dt)
	currentCameraDistance = math.lerp(currentCameraDistance, cameraDistance, zoomSentivity)
	player.CameraMinZoomDistance = currentCameraDistance
	player.CameraMaxZoomDistance = currentCameraDistance
end)

-- Disconnector
local humanoid = player.Character:WaitForChild("Humanoid")
humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
	if not humanoid.SeatPart then
		GamepadService:DisableGamepadCursor()
		GuiService.AutoSelectGuiEnabled = true
		
		RunFunction:Disconnect()
		ContextActionService:UnbindAction("Increase Collective")
		ContextActionService:UnbindAction("Toggle Camera Cycles")
		ContextActionService:UnbindAction("Toggle Gamepad Cursor")
	end
end)]]></ProtectedString>
