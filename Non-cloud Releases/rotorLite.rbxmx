					<Item class="Script" referent="RBX4E6949529F71460AB8236F74B25FF44C">
						<Properties>
							<ProtectedString name="Source"><![CDATA[task.wait(1)
----- Settings -----
local rotor_RPM = 530
local tailRotorRPM_Ratio = 5
--------------------
script:SetAttribute("RPM", rotor_RPM)

local rotors = script.Parent
local top_Rotor = rotors.TopRotor.Main.Motor
local tail_Rotor = rotors.TailRotor.Main.Motor

local Stats_ = script.Parent.Parent.Stats

local power, currentPower = 0, 0

local RS = game:GetService("RunService")

local lastTime = os.clock()
while true do
	local currentTime = os.clock()
	local deltaTime = currentTime - lastTime
	lastTime = currentTime
	--------------------
	local active = Stats_:GetAttribute("Active") == true
	local collective = Stats_:GetAttribute("Collective")
	local speed = top_Rotor.Parent.AssemblyLinearVelocity.Magnitude
	
	power = active and 50 + (math.clamp(collective + speed/100, 0, 0.1) * 500) or 0
	currentPower = math.clamp(currentPower + 10 * (currentPower < power and deltaTime or -deltaTime), 0, 100)
	--------------------
	top_Rotor.AngularVelocity = rotor_RPM/10 * currentPower/100
	tail_Rotor.AngularVelocity = rotor_RPM/10 * tailRotorRPM_Ratio * currentPower/100
	
	task.wait(0.06)
end]]></ProtectedString>
