			<Item class="Script" referent="RBX0FA538AB02194CE79ABEBE39D0509260">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--[ SKYtech rotorLite ]--

local Settings = {

	AircraftStatistics = {
		Stability = 0.7, -- How stable a forward flight is (less = more drift)
		Sensitivity = 0.5, -- How fast a helicopter changes the direction (0-1)
		RateOfClimb = 35,
		Acceleration = 0.1,
		MaxSpeed = 200, -- 25% slower at max altitude
		MaxAltitude = 15000,
		TorqueResponsiveness = 40,
		-- Between 5-200, how fast the control responses. Good for big aircraft that want smooth turning.
	},

	FuelSystem = {
		Enabled = true,
		Consumption = 0.025, -- Percent per second
	},
	
	-- A custom control script can be added into the loader, ignoring FlightControls (except FollowCamera) below.
	FlightControls = {
		FollowCamera = true, -- Determine if the helicopter should follow the camera direction or not.
		CameraType = "Custom",
		--( "Custom", "Scriptable", "Attach", "Follow", "Track", "Orbital", "Fixed", "Watch" )--
		CursorIcon = "rbxassetid://105110588062984",
		ToggleControl = Enum.KeyCode.C, -- Set "nil" (with quotation marks) if you want to force the control on.
		Engine = Enum.KeyCode.E, -- Set "nil" if you have a custom startup script.
		CollectiveUp = Enum.KeyCode.W, -- Basically throttle, but in helicopter term.
		CollectiveDown = Enum.KeyCode.S,
		CollectiveIncrement = 0.5,
		LandingGear = Enum.KeyCode.G,
		-- Non-follow camera configuration for mobile and gamepad (if have)
		
		-- Non-advanced configuration for mobile (if have)
		MobileRange = Vector2.new(45, 45), -- (Horizontal, Vertical), 0-90 degrees

		-- Gamepad/console controls (if have)
		Gamepad = {
			LockCamera = Enum.KeyCode.ButtonL3, --[[ Set "nil" (with quotation marks) if you want to force the camera locked.
			The locked camera type depends on the "CameraType" above.	]]
			Engine = Enum.KeyCode.ButtonY, -- Set "nil" (with quotation marks) if you have a custom startup script.
			CollectiveUp = Enum.KeyCode.ButtonA, -- If it's the ButtonA, the mod has a special function to make it work.
			CollectiveDown = Enum.KeyCode.ButtonB,
			LandingGear = Enum.KeyCode.DPadDown,
		},
		GamepadCameraCycles = {1.5, 1, 0.65, 0}, -- Fartest to closest camera distance scales based on the aircraft's size.
	},

	Modifications = { -- Your custom settings here
		--[[ A built-in group lock mod for you. You can remove it if you want to.
		The script is in the "Mods" folder inside the "Main" section.	]]
		GroupLock = false,
		GroupID = 0,
		GroupRank = 10, -- Minimum rank that can access the aircraft
	},
	
	Advanced = {
		PhysicsScale = 1, -- Physics multiplier (max speed, acceleration, etc)
		ClientControlled = true, -- Pilot takes network ownership by default, allowing instantaneous response.
		ResetNetwork = true, -- Reset network ownership when the pilot exits, otherwise remain with the previous pilot.
	},

}

--[[ This transforms a settings table into attributes so they can be modfied in game.
* DO NOT EDIT BELOW UNLESS YOU KNOW WHAT YOU ARE DOING * ]]
local configuration = Instance.new("Configuration")
configuration.Name = "Settings"
for i, c in pairs(Settings) do
	for n, v in pairs(c) do
		if typeof(v) == "EnumItem" then -- KeyCode
			configuration:SetAttribute(i.."/"..n, v.Name)
		elseif typeof(v) == "table" then
			for j, k in pairs(v) do
				if typeof(k) == "EnumItem" then -- KeyCode
					configuration:SetAttribute(i.."/"..n.."/"..j, k.Name)
				else
					configuration:SetAttribute(i.."/"..n.."/"..j, k)
				end
			end
		else
			configuration:SetAttribute(i.."/"..n, v)
		end
	end
end

local vehicle = script.Parent
configuration.Parent = vehicle
vehicle:AddTag("SKYtech rotorLite") -- Tag is required for the system to load.

--require(12918838841) -- Load the source module from cloud.]]></ProtectedString>
