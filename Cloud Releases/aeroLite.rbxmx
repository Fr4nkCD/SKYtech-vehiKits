									<Properties>
										<ColorSequence name="Color">0 1 1 1 0 1 0.835294 0.835294 0.835294 0 </ColorSequence>
										<bool name="Enabled">true</bool>
										<Vector2 name="Offset">
											<X>0</X>
											<Y>0</Y>
										</Vector2>
