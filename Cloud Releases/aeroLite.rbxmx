							<Item class="LocalScript" referent="RBX45F7E8BFFB754CAF96F4537F9ED8E92E">
								<Properties>
									<ProtectedString name="Source"><![CDATA[-- Imagine writing a very complicated script just to make instructions. --

local UIS = game:GetService("UserInputService")
if UIS:GetLastInputType() == Enum.UserInputType.Touch or UIS:GetLastInputType() == Enum.UserInputType.Gamepad1 then
	script.Parent:Destroy() -- Delete if it's a mobile or gamepad
	return
end

local aircraft = script.Parent.Parent.Aircraft.Value
local Settings = aircraft.Settings

local panel = script.Parent.Panel

script.Parent.Toggle.MouseButton1Click:Connect(function() -- Toggle panel
	panel.Visible = not panel.Visible
end)

local template = panel.C0
template.Visible = false
function createGuide(key_Size, description, key)
	local guide = template:Clone()
	guide.Name = description
	guide.Visible = true
	guide.Parent = panel
	--------------------
	guide.Description.Size = UDim2.new(1 - key_Size, 0, 0.8, 0)
	guide.Key.Size = UDim2.new(key_Size, 0, 0.925, 0)
	--------------------
	guide.Description.Value.Text = description
	guide.Key.Text = key
end

---------------- Setup ----------------
if Settings:GetAttribute("FlightControls/Engine") ~= "nil" then
	createGuide(0.15, "Engine", Settings:GetAttribute("FlightControls/Engine"))
end

createGuide(0.3, "Throttle", Settings:GetAttribute("FlightControls/ThrottleUp").." / "..Settings:GetAttribute("FlightControls/ThrottleDown"))
createGuide(0.15, "Brake", Settings:GetAttribute("FlightControls/Brake"))

if Settings:GetAttribute("FlightControls/ToggleControl") ~= "nil" then
	createGuide(0.15, "Take Control", Settings:GetAttribute("FlightControls/ToggleControl"))
end

local VTOL_Mod = script.Parent.Parent:FindFirstChild("VTOL_Vector_Controls")
if VTOL_Mod then
	createGuide(0.275, "VTOL", VTOL_Mod:GetAttribute("Up_InputKey").." / "..VTOL_Mod:GetAttribute("Down_InputKey")) -- Mod
end

createGuide(0.4, "Roll & Pitch", "Mouse")
createGuide(0.275, "Yaw", "A / D")

if Settings:GetAttribute("FlightControls/LandingGear") then
	local landingGear = aircraft.Main.Mods:FindFirstChild("LandingGear")
	if landingGear and landingGear:GetAttribute("Available") == true then
		createGuide(0.15, "Landing Gear", Settings:GetAttribute("FlightControls/LandingGear"))
	end
end
	
--------------------- Extra stuff ---------------------

local Stats_ = aircraft.Main.Stats
local mouseGuide = panel:FindFirstChild("Roll & Pitch")
local yawGuide = panel:FindFirstChild("Yaw")

function checkAdvancedControl()
	local isAdvanced = Settings:GetAttribute("AttitudeControls/Advanced") == true
	local isVTOL = Stats_:GetAttribute("VTOL/Active") == true
	
	mouseGuide.Description.Value.Text = if isVTOL then "Pitch & Yaw" else "Roll & Pitch"
	yawGuide.Description.Value.Text = if isVTOL then "Roll" else "Yaw"
	yawGuide.Visible = isAdvanced or isVTOL
end

checkAdvancedControl()

Settings:GetAttributeChangedSignal("AttitudeControls/Advanced"):Connect(checkAdvancedControl)
Stats_:GetAttributeChangedSignal("VTOL/Active"):Connect(checkAdvancedControl)]]></ProtectedString>
