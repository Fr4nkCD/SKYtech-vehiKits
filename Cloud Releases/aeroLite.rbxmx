					<Item class="Script" referent="RBX485C64502B4040149321889ADFE849FC">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Stats_ = script.Parent.Parent.Parent.Main.Stats

function animate()
	local on = (Stats_:GetAttribute("VTOL/Percent") > 0 and Stats_:GetAttribute("VTOL/Active") == true) and math.rad(90) or 0

	script.Parent.L1.Motor.DesiredAngle = on
	script.Parent.L2.Motor.DesiredAngle = on
	script.Parent.L3.Motor.DesiredAngle = on
	script.Parent.L4.Motor.DesiredAngle = on

	script.Parent.R1.Motor.DesiredAngle = on
	script.Parent.R2.Motor.DesiredAngle = on
	script.Parent.R3.Motor.DesiredAngle = on
	script.Parent.R4.Motor.DesiredAngle = on
end

Stats_.AttributeChanged:Connect(function(attrName)
	if attrName:find("VTOL") then
		animate()
	end
end)]]></ProtectedString>
