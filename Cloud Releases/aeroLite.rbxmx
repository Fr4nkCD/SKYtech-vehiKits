									<Content name="LinkedSource"><null></null></Content>
									<ProtectedString name="Source"><![CDATA[-- VTOL Bridge Module
-- Bridge between the aeroLite and rotorLite modules

local module = {
	States = {}
}

local aeroLite = script.Parent
local modules = script.Parent.Parent

local Utils = require(modules:WaitForChild("VehicleUtils"))

local rotorLiteModule = modules:WaitForChild("rotorLite", 1)
if not rotorLiteModule then
	warn("VTOL: rotorLite not found, switching to the backup flight physics module.")
	rotorLiteModule = aeroLite:WaitForChild("VTOL_FlightPhysics")
end

local rotorLite = require(rotorLiteModule)

----------------------------------------------------------------------------------------------------

function module:Initialize(aircraft)
	local main = aircraft.Main
	local mainPart = main.Main
	local VTOL_Attachment = mainPart.VTOL

	self.States[aircraft] = {
		System = {
			VTOL = false,
			Roll = 0,
			Pitch = 0,
			Yaw = 0,
			Collective = 0,
			Percent = 0,
			--------------------------
			LookVector = Vector3.zero,
			Forward = 0,
			Forward_Drag = 0,
			Sideways_Speed = 0,
			Velocity = Vector3.zero,
			Direction = CFrame.new(),
			MotionCFrame = CFrame.new(),
			MaxForce = Vector2.zero,
		},
		Settings = {},
		Connections = {},
		Components = {
			StateWrapper = aircraft.System,
			Stats_ = main.Stats,
			MainPart = mainPart,
			Motion = mainPart.Motion,
			Turn = mainPart.Turn,
			Thrust = mainPart.Thrust,
			Lift = mainPart.Lift,
			Gravity = mainPart.Gravity,

			VTOL_Lift = VTOL_Attachment.Lift,
			VTOL_Motion = VTOL_Attachment.Motion,
			VTOL_Gravity = VTOL_Attachment.Gravity,
			VTOL_UpdateEvent = main.Mods.VTOL.Update
		},
		Step = 0,
		ForwardState = require(aircraft.System),
		VTOLState = {},
	}

	local state = self.States[aircraft]

	local Settings = aircraft:FindFirstChild("Settings")

	for attrName, attrValue in pairs(Settings:GetAttributes()) do
		Utils.UpdateSetting(attrName, attrValue, state.Settings)
	end	
	table.insert(state.Connections, Settings.AttributeChanged:Connect(function(attrName)
		local attrValue = Settings:GetAttribute(attrName)
		if attrValue == nil then return end
		Utils.UpdateSetting(attrName, attrValue, state.Settings)

		if attrName:find("Acceleration") then
			-- Override rotorLite's acceleration to avoid conflict with the aeroLite.
			state.VTOLState.Settings.AircraftStatistics.Acceleration = state.Settings.AircraftStatistics.VTOLAcceleration
		end
	end))

	self:Reset(aircraft)

	rotorLite:Initialize(aircraft)

	state.VTOLState = rotorLite:GetState(aircraft)

	local VTOLState = state.VTOLState
	VTOLState.Components.Lift = state.Components.VTOL_Lift
	VTOLState.Components.Motion = state.Components.VTOL_Motion
	VTOLState.Components.Gravity = state.Components.VTOL_Gravity
	-- Override rotorLite's acceleration to avoid conflict with aeroLite.
	VTOLState.Settings.AircraftStatistics.Acceleration = state.Settings.AircraftStatistics.VTOLAcceleration

	return state.System
end

function module:GetState(aircraft)
	return self.States[aircraft]
end

function module:Reset(aircraft)
	local state = self.States[aircraft]
	local mainPart = state.Components.MainPart
	state.Components.VTOL_Motion.CFrame = mainPart.CFrame
end

function module:Update(aircraft, dt, onClient)
	local state = self.States[aircraft]

	if not state then return end

	state.Step += dt

	local System : SharedTable = state.System
	local Settings = state.Settings
	local Components = state.Components

	local stateWrapper = Components.StateWrapper

	local ForwardState = state.ForwardState
	local VTOLState = state.VTOLState
	local VTOLSystem = VTOLState.System

	local mainPart = Components.MainPart
	local motion = Components.Motion
	local turn = Components.Turn
	local thrust = Components.Thrust
	local lift = Components.Lift
	local gravity = Components.Gravity
	local Stats_ = Components.Stats_
	local VTOL_Motion = Components.VTOL_Motion
	local VTOL_Lift = Components.VTOL_Lift
	local VTOL_Gravity = Components.VTOL_Gravity

	--------------------------- Variables ---------------------------
	local physicsScale = Utils.Max(Settings.Advanced.PhysicsScale, 0.001)
	local _acceleration = Settings.AircraftStatistics.Acceleration * physicsScale
	local _maxSpeed = Settings.AircraftStatistics.MaxSpeed * physicsScale
	local _stallSpeed = Utils.Max(Settings.AircraftStatistics.StallSpeed * physicsScale, 0.001)
	local _maxAltitude = Utils.Max(Settings.AircraftStatistics.MaxAltitude * physicsScale, 0.001)
	local changedbyAltitude = Settings.AircraftStatistics.ChangedbyAltitude == true

	local mainCFrame = mainPart.CFrame
	local bankAngle = -Utils.Deg(Utils.GetRoll(mainCFrame)) + 360
	local pitchRad, _, _ = mainCFrame:ToEulerAnglesYXZ()
	local pitchAngle = Utils.Deg(pitchRad)
	VTOLSystem.Forward += _acceleration * Utils.Clamp(1 - (System.Percent - 0.25)/0.75 + Utils.Abs(pitchAngle)/90, 0, 1)

	System.Collective = Utils.Clamp(System.Collective - (1 - System.Percent), 0, 1)

	----------------------------------------------------
	local altitude = mainPart.Position.Y
	local stallSpeedChangedbyAltitude = if changedbyAltitude then (_maxSpeed - _stallSpeed) * Utils.Clamp((altitude/_maxAltitude) + Utils.Clamp((altitude - _maxAltitude)/10, 0, 10), 0, 10) else 0
	local liveStallSpeed = _stallSpeed + (Utils.Abs(bankAngle/180) * (_stallSpeed/3)) + stallSpeedChangedbyAltitude
	local VTOL_StallSpeed = liveStallSpeed * (1 - System.Percent)

	if VTOLSystem.Velocity.Magnitude >= VTOL_StallSpeed and not stateWrapper:GetAttribute("Flying") and Stats_:GetAttribute("Active") == true and System.Percent > 0 then
		if System.VTOL == false then
			System.VTOL = true
			VTOLSystem.Forward += physicsScale
		end

		VTOL_Lift.Enabled = true
		VTOL_Motion.Enabled = true
		VTOL_Gravity.Enabled = true

		thrust.Enabled = false
		lift.Enabled = false
		motion.Enabled = false
		turn.Enabled = false
		gravity.Enabled = false
	else
		if System.VTOL == true then
			System.VTOL = false
			VTOLSystem.Forward -= physicsScale

			local velocity = mainPart.AssemblyLinearVelocity
			local speed = -mainCFrame:VectorToObjectSpace(velocity).Z
			ForwardState.Speed = (speed + VTOLSystem.Forward) / 2
		end

		VTOL_Lift.Enabled = false
		VTOL_Motion.Enabled = false
		VTOL_Gravity.Enabled = false

		thrust.Enabled = true
		lift.Enabled = true
		motion.Enabled = true
		turn.Enabled = true
		gravity.Enabled = true
	end

	Stats_:SetAttribute("VTOL/Active", System.VTOL)
	Stats_:SetAttribute("VTOL/Percent", System.Percent * 100)

	if state.Step >= 0.5 and onClient then
		Components.VTOL_UpdateEvent:FireServer(System.VTOL, System.Percent * 100)
		state.Step = 0
	end

	VTOLSystem.Collective = System.Collective
	VTOLSystem.Percent = System.Percent
	VTOLSystem.Roll = System.Roll
	VTOLSystem.Pitch = System.Pitch
	VTOLSystem.Yaw = System.Yaw
	VTOLSystem.MousePosition = System.MousePosition

	rotorLite:Update(aircraft, dt, onClient)
end

function module:Cleanup(aircraft)
	rotorLite:Cleanup(aircraft)

	local state = self.States[aircraft]

	for i, connection in pairs(state.Connections) do
		connection:Disconnect()
	end
	state.Connections = nil

	self.States[aircraft] = nil
end

return module
]]></ProtectedString>
									<string name="ScriptGuid">{9594AE9A-B921-43DA-9178-0FAE5F4A4E02}</string>
									<BinaryString name="AttributesSerialize"></BinaryString>
									<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
									<bool name="DefinesCapabilities">true</bool>
									<string name="Name">VTOL_Bridge</string>
									<int64 name="SourceAssetId">-1</int64>
