								</Properties>
							</Item>
							<Item class="ModuleScript" referent="RBX08A192FA05D74DFFB87FB7A5AA4FFB64">
								<Properties>
									<Content name="LinkedSource"><null></null></Content>
									<ProtectedString name="Source"><![CDATA[-- rotorLite Flight Physics
-- by SKYtech
-- The actual rotorLite module added as a backup for the VTOL mod.

local module = {
	States = {}
}

-- Utilies (math, physics, global variables)
local Utils = require(script.Parent.Parent:WaitForChild("VehicleUtils"))
-- script > Parent > Parent
-- VTOL_FlightPhysics > aeroLite > SKYtech Systems (folder)

function module:Initialize(aircraft)
	local main = aircraft.Main
	local mainPart = main.Main

	self.States[aircraft] = {
		System = {
			Collective = 0,
			Roll = 0,
			Pitch = 0,
			Yaw = 0,
			-----------------------
			Forward = 0,
			Forward_Drag = 0,
			SidewaysSpeed = 0,
			Velocity = Vector3.zero,
			Direction = Vector3.zero,
			RollAccumulated = 0,
			MotionCFrame = CFrame.new(),
			MaxForce = 0,
		},
		Settings = {},
		Connections = {},
		Components = {
			MainPart = mainPart,
			Motion = mainPart.Motion,
			Lift = mainPart.Lift,
			Gravity = mainPart.Gravity,
			Stats_ = main.Stats,
		},
	}

	local state = self.States[aircraft]

	local Settings = aircraft:FindFirstChild("Settings")

	-- Initialize settings.
	for attrName, attrValue in pairs(Settings:GetAttributes()) do
		Utils.UpdateSetting(attrName, attrValue, state.Settings)
	end	

	-- Update legacy value objects on the client side.
	if Utils.IsClient() then
		Utils.SyncLegacyValues(Settings, state.Connections)
	end

	-- Update settings on attribute changed.
	table.insert(state.Connections, Settings.AttributeChanged:Connect(function(attrName)
		local attrValue = Settings:GetAttribute(attrName)
		if attrValue == nil then return end
		Utils.UpdateSetting(attrName, attrValue, state.Settings)
	end))

	self:Reset(aircraft)
end

function module:GetState(aircraft)
	return self.States[aircraft]
end

function module:Reset(aircraft)
	local state = self.States[aircraft]

	local System = state.System
	local Settings = state.Settings

	local Components = state.Components
	local Stats_ = Components.Stats_
	local mainPart = Components.MainPart

	local physicsScale = Utils.Max(Settings.Modifications.PhysicsScale or Settings.Advanced.PhysicsScale, 0.001)
	local mainCFrame = mainPart.CFrame
	local velocity = mainPart.AssemblyLinearVelocity/physicsScale
	local bankAngle = -Utils.Deg(Utils.GetRoll(mainCFrame)) + 360

	System.MaxForce = Utils.Clamp(System.Collective/0.1 + velocity.Magnitude/20, 0, 1) * (if Stats_:GetAttribute("Active") == true then 1 else 0)
	System.Forward = -mainCFrame:VectorToObjectSpace(velocity).Z
	System.SidewaysSpeed = mainCFrame:VectorToObjectSpace(velocity).X
	System.Velocity = velocity * physicsScale
	System.RollAccumulated = Utils.Rad(bankAngle)
	System.Direction = mainCFrame.LookVector * 1e6
	System.MotionCFrame = mainCFrame
end

function module:Update(aircraft, dt, onClient)	
	local state = self.States[aircraft]

	if not state then return end

	local System = state.System
	local Settings = state.Settings
	local Components = state.Components

	local Stats_ = Components.Stats_
	local mainPart = Components.MainPart
	local motion = Components.Motion
	local lift = Components.Lift
	local gravity = Components.Gravity

	-- Variables that need to be updated every frame.
	local physicsScale = Utils.Max(Settings.Modifications.PhysicsScale or Settings.Advanced.PhysicsScale, 0.001)
	local globalWind = workspace.GlobalWind
	local globalGravity = workspace.Gravity
	local mainCFrame = mainPart.CFrame
	local position = mainPart.Position
	local velocity = mainPart.AssemblyLinearVelocity/physicsScale
	local altitude = position.Y
	local bankAngle = -Utils.Deg(Utils.GetRoll(mainCFrame)) + 360
	local isInverted = bankAngle%360 >= 90 and bankAngle%360 <= 270
	local invertedBankAngle = Utils.Deg(Utils.GetRoll(mainCFrame * Utils.CFAngles(0, 0, Utils.Pi))) - 360
	local pitchRad, yawAngle, _ = mainCFrame:ToEulerAnglesYXZ()
	local pitchAngle = Utils.Deg(pitchRad)
	local collective = Utils.Clamp(System.Collective/0.1 + velocity.Magnitude/20, 0, 1) * (if Stats_:GetAttribute("Active") == true then 1 else 0)

	-- Only run physics if the aircraft is unanchored.
	if not mainPart:IsGrounded() then
		--------------------------- Variables ---------------------------
		local _sensitivity = Utils.Max(Settings.AircraftStatistics.Sensitivity, 0.001)
		local _stability = Utils.Max(Settings.AircraftStatistics.Stability, 0.001)
		local _torqueResponsiveness = Utils.Max(Settings.AircraftStatistics.TorqueResponsiveness, 0.001)
		local _rateOfClimb = Settings.AircraftStatistics.RateOfClimb * physicsScale
		local _acceleration = Settings.AircraftStatistics.Acceleration * physicsScale
		local _maxSpeed = Utils.Max(Settings.AircraftStatistics.MaxSpeed * physicsScale, 0.001)
		local _maxAltitude = Utils.Max(Settings.AircraftStatistics.MaxAltitude * physicsScale, 0.001)
		------------------------------------------------------------------
		local forceAlpha = 1 - Utils.Exp(-10 * (0.5 + _sensitivity/2) * dt)
		System.MaxForce = Utils.Lerp(System.MaxForce, collective, forceAlpha)
		------------------------------------------------------------------
		local mass = mainPart.AssemblyMass
		lift.MaxForce = mass * 100 * System.MaxForce
		motion.MaxTorque = mass * 2000 * System.MaxForce
		----------------------------------------------------
		local upperCollective = Utils.Min(Utils.Max(System.Collective - 0.5, 0)/0.5, 1)
		local lowerCollective = 1 - Utils.Min(System.Collective/0.5, 1)

		local ascend = mainCFrame.UpVector * upperCollective * Utils.Max(upperCollective, 0.8) * _rateOfClimb
		local descend = Utils.V3New(0, -(lowerCollective * Utils.Max(lowerCollective, 0.8)) * _rateOfClimb, 0)

		local maxSpeed = _maxSpeed - (_maxSpeed*0.25 * altitude/_maxAltitude)
		System.Forward_Drag = (if System.Forward < 0 then 0.05 else -0.05) * physicsScale
		local drag_Damping = Utils.Min(Utils.Abs(System.Forward/physicsScale), 1)
		local acceleration = -pitchAngle/10 * _acceleration
		System.Forward = Utils.Clamp(System.Forward + acceleration + System.Forward_Drag * drag_Damping, -maxSpeed, maxSpeed)

		local sidewaysMaxSpeed = maxSpeed/4
		local sideways_Drag = Utils.Clamp(-System.SidewaysSpeed/physicsScale, -0.1, 0.1) * physicsScale
		local sideSlip = (if isInverted then invertedBankAngle else bankAngle)/10 * _acceleration * -Utils.Max(1 - velocity.Magnitude/100, 0)
		System.SidewaysSpeed = Utils.Clamp(System.SidewaysSpeed + sideSlip + sideways_Drag, -sidewaysMaxSpeed, sidewaysMaxSpeed)

		local maxAltitude = Utils.V3New(1, Utils.Clamp(_maxAltitude - altitude, 0, 1), 1)
		local altitudeDrop = Utils.V3New(0, Utils.Clamp((_maxAltitude - 1) - altitude, -_rateOfClimb, 0), 0)
		local crosswind = globalWind * Utils.Min(velocity.Magnitude/25, 1)
		------------------
		local stabilitySpeed = 1 + 2^(Utils.Abs(System.Forward)/_maxSpeed)
		local stabilityAlpha = 1 - Utils.Exp(-_stability * stabilitySpeed * dt)
		local horizontalVector = Utils.V3New(1, 0.25, 1)
		System.Velocity = System.Velocity:Lerp((ascend + descend + (mainCFrame.LookVector * System.Forward * horizontalVector) + (mainCFrame.RightVector * System.SidewaysSpeed * horizontalVector)) * maxAltitude + altitudeDrop + crosswind, stabilityAlpha)
		lift.VectorVelocity = System.Velocity
		-------------------------------------------------------------------------------------------------
		motion.MaxAngularVelocity = Utils.Clamp(_sensitivity * 3, 1, 3)
		if System.MaxForce > 0.01 then
			local alpha = 1 - Utils.Exp(-_sensitivity/0.5 * dt)
			local nosePosition = mainCFrame.LookVector * 1e6

			local targetDir = (System.MousePosition or nosePosition).Unit
			System.Direction = System.Direction:Lerp(targetDir, alpha).Unit

			local targetPosition = position + (System.Direction * 1e6)
			local flatMask = Utils.V3New(1, 0, 1)
			local start2D = nosePosition * flatMask
			local target2D = targetPosition * flatMask

			local maxAngle = Utils.Pi/4 + Utils.Pi/8 * _sensitivity

			if start2D.Magnitude > 0.001 and target2D.Magnitude > 0.001 then
				local turnAngle = math.acos(Utils.Clamp(start2D.Unit:Dot(target2D.Unit), -1, 1))
				local turnSign = Utils.Sign(Vector3.yAxis:Dot(start2D:Cross(target2D)))

				local speedFactor = Utils.Min(velocity.Magnitude / 10, 5)

				local manualRollTarget = System.Roll * maxAngle
				local autoRollTarget = (turnAngle^(1 + _sensitivity) * turnSign) * (_sensitivity * 5) * speedFactor
				local manualRollOverride = 1 - Utils.Abs(System.Roll)
				autoRollTarget = Utils.Clamp(autoRollTarget * manualRollOverride + manualRollTarget, -maxAngle, maxAngle)

				local dive = 1 - Utils.Max(Utils.Abs(pitchAngle) - 60, 0)/30
				System.RollAccumulated = Utils.Lerp(System.RollAccumulated * dive, autoRollTarget, alpha)
			end

			local finalRollAngle = Utils.Clamp(System.RollAccumulated, -maxAngle, maxAngle)

			local direction = CFrame.lookAt(position, targetPosition)
			local roll = Utils.CFAngles(0, 0, finalRollAngle)

			System.MotionCFrame = direction * roll
		else
			System.Forward = -mainCFrame:VectorToObjectSpace(velocity).Z
			System.SidewaysSpeed = mainCFrame:VectorToObjectSpace(velocity).X
			System.Velocity = Utils.V3Zero
			System.Direction = mainCFrame.LookVector * 1e6
			System.MotionCFrame = mainCFrame
		end

		gravity.Force = Utils.V3New(0, mass * Utils.Max(globalGravity - 35, 0) * System.MaxForce, 0)

		local responsiveness = Utils.Clamp((10 + _torqueResponsiveness) * stabilityAlpha, 0, 0.25) 
		motion.CFrame = motion.CFrame:Lerp(System.MotionCFrame, responsiveness)
		--- Debug for modding ---
		if not lift.Enabled then
			System.Forward = -mainCFrame:VectorToObjectSpace(velocity).Z
			System.SidewaysSpeed = mainCFrame:VectorToObjectSpace(velocity).X
			System.Velocity = velocity * physicsScale
		end
		if not motion.Enabled then
			System.RollAccumulated = Utils.Rad(bankAngle)
			System.Direction = mainCFrame.LookVector * 1e6
			System.MotionCFrame = mainCFrame
		end
	else
		-- Don't run physics if anchored.
		System.MaxForce = collective
		System.Forward = -mainCFrame:VectorToObjectSpace(velocity).Z
		System.SidewaysSpeed = mainCFrame:VectorToObjectSpace(velocity).X
		System.Velocity = velocity * physicsScale
		System.RollAccumulated = Utils.Rad(bankAngle)
		System.Direction = mainCFrame.LookVector * 1e6
		System.MotionCFrame = mainCFrame
	end
end

function module:Cleanup(aircraft)
	local state = self.States[aircraft]

	for i, connection in pairs(state.Connections) do
		connection:Disconnect()
	end
	state.Connections = nil

	self.States[aircraft] = nil
end

return module
]]></ProtectedString>
									<string name="ScriptGuid">{706A2B6E-70DB-4118-B804-DBEE65819AD2}</string>
									<BinaryString name="AttributesSerialize"></BinaryString>
									<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
									<bool name="DefinesCapabilities">true</bool>
