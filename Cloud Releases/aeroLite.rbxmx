							<Item class="LocalScript" referent="RBXB81F1BD2E68B4AE88D684E4E502DF70F">
								<Properties>
									<ProtectedString name="Source"><![CDATA[local panel = script.Parent
panel.Visible = false -- Hide first if the module fails

local aircraft = panel.Parent.Aircraft.Value
local Settings = aircraft.Settings

local Stats_ = aircraft.Main.Stats
local mainPart = aircraft.Main.Main

local core = require(game:GetService("ReplicatedStorage"):FindFirstChild("SKYtech Systems"):FindFirstChild("Modules"):FindFirstChild("aeroLite"):FindFirstChild("VTOL_Bridge"))

core:Initialize(aircraft)
core:Reset(aircraft)

panel.Visible = true -- Reappear

local moduleState = core:GetState(aircraft)

local controller = panel.Parent.Controller
local control_Handler = panel.Parent.Control_Handler
local throttle = control_Handler.Throttle
local roll, pitch, yaw = control_Handler.Roll, control_Handler.Pitch, control_Handler.Yaw

local lastRollInput, lastPitchInput = 0, 0

local VTOL_Input = 0
local percent = Stats_:GetAttribute("VTOL/Percent") * 100

local Keybinds = {
	VectorUp = Settings:GetAttribute("FlightControls/VectorUp"),
	VectorDown = Settings:GetAttribute("FlightControls/VectorDown")
}
local GamepadKeybinds = {
	VectorUp = Settings:GetAttribute("FlightControls/Gamepad/VectorUp"),
	VectorDown = Settings:GetAttribute("FlightControls/Gamepad/VectorDown")
}

local UIS = game:GetService("UserInputService")

UIS.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode[Keybinds.VectorUp] or input.KeyCode == Enum.KeyCode[GamepadKeybinds.VectorUp] then
		VTOL_Input = 1
	elseif input.KeyCode == Enum.KeyCode[Keybinds.VectorDown] or input.KeyCode == Enum.KeyCode[GamepadKeybinds.VectorDown] then
		VTOL_Input = -1
	end
end)

UIS.InputEnded:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode[Keybinds.VectorUp] or input.KeyCode == Enum.KeyCode[Keybinds.VectorDown] or
		input.KeyCode == Enum.KeyCode[GamepadKeybinds.VectorUp] or input.KeyCode == Enum.KeyCode[GamepadKeybinds.VectorDown]
	then
		VTOL_Input = 0
	end
end)

local RunService = game:GetService("RunService")

RunService.Heartbeat:Connect(function(dt)
	percent = math.clamp(percent + (dt * 40 * VTOL_Input), 0, 100)

	local states = moduleState.System

	states.Collective = throttle.Size.Y.Scale
	states.Percent = percent/100

	local pitchInput = pitch.Size.Y.Scale/2
	local rollInput = roll.Size.Y.Scale

	states.Roll = yaw.Size.Y.Scale
	states.Pitch = pitchInput
	states.Yaw = rollInput

	if rollInput ~= 0 then lastRollInput = rollInput end
	if pitchInput ~= 0 then lastPitchInput = pitchInput end

	local position = mainPart.Position

	if rollInput ~= 0 or pitchInput ~= 0 then
		local _, yawAngle, _ = mainPart.CFrame:ToOrientation()
		local direction = CFrame.Angles(0, yawAngle, 0) * CFrame.Angles(
			math.rad(45 * lastPitchInput),
			math.rad(45 * lastRollInput), 0)
		states.MousePosition = position + (direction.LookVector * 1e6)
	else
		states.MousePosition = position + (mainPart.CFrame.LookVector * 1e6)
	end

	core:Update(aircraft, dt, true)
end)

RunService:BindToRenderStep("Update VTOL Instruments", Enum.RenderPriority.Camera.Value + 1, function(dt)
	local barPercent = 1 - percent/100
	panel.Bar.Position = UDim2.new(-barPercent, 0, 0, 0)
	panel.Bar.Value.Position = UDim2.new(barPercent, 0, 0, 0)
	panel.Value.Text = math.round((math.round(percent/5)/20) * 100)
end)

panel.Increase.Text = Keybinds.VectorUp
panel.Decrease.Text = Keybinds.VectorDown

local activeInput = nil

panel.Increase.InputBegan:Connect(function(input, processed)
	if processed or (input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1) then return end

	if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
		activeInput = input
		VTOL_Input = 1
	end
end)

panel.Decrease.InputBegan:Connect(function(input, processed)
	if processed or (input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1) then return end

	if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
		activeInput = input
		VTOL_Input = -1
	end
end)

UIS.InputEnded:Connect(function(input)
	if input == activeInput then
		activeInput = nil
		VTOL_Input = 0
	end
end)

panel:SetAttribute("Up_InputKey", Keybinds.VectorUp)
panel:SetAttribute("Down_InputKey", Keybinds.VectorDown)

if UIS:GetLastInputType() == Enum.UserInputType.Touch or UIS:GetLastInputType() == Enum.UserInputType.Gamepad1 then
	panel.Increase.Text = "+"
	panel.Decrease.Text = "-"
	panel.Increase.TextSize = 28
	panel.Decrease.TextSize = 28
end]]></ProtectedString>
