					<Item class="Script" referent="RBXD2EB232350C34327976F1B27EE37D3CB">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Stats_ = script.Parent.Parent.Parent.Main.Stats

local E1 = script.Parent.E1
local E2 = script.Parent.E2

local TS = game:GetService("TweenService")

function animate()
	if Stats_:GetAttribute("Active") == false then return end
	
	local RPM = 10 + (20 * Stats_:GetAttribute("Throttle"))
	E1.Motor.MaxVelocity = RPM
	E2.Motor.MaxVelocity = RPM
end

Stats_:GetAttributeChangedSignal("Active"):Connect(function()
	if Stats_:GetAttribute("Active") == true then
		TS:Create(E1.Fan.Static1, TweenInfo.new(1), {Transparency = 1}):Play()
		TS:Create(E1.Fan.Static2, TweenInfo.new(1), {Transparency = 1}):Play()
		TS:Create(E2.Fan.Static1, TweenInfo.new(1), {Transparency = 1}):Play()
		TS:Create(E2.Fan.Static2, TweenInfo.new(1), {Transparency = 1}):Play()
		
		TS:Create(E1.Fan.Blur1, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E1.Fan.Blur2, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E2.Fan.Blur1, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E2.Fan.Blur2, TweenInfo.new(1), {Transparency = 0}):Play()
		
		E1.Motor.MaxVelocity = 10
		E2.Motor.MaxVelocity = 10
	else
		TS:Create(E1.Fan.Static1, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E1.Fan.Static2, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E2.Fan.Static1, TweenInfo.new(1), {Transparency = 0}):Play()
		TS:Create(E2.Fan.Static2, TweenInfo.new(1), {Transparency = 0}):Play()
		
		TS:Create(E1.Fan.Blur1, TweenInfo.new(3), {Transparency = 1}):Play()
		TS:Create(E1.Fan.Blur2, TweenInfo.new(3), {Transparency = 1}):Play()
		TS:Create(E2.Fan.Blur1, TweenInfo.new(3), {Transparency = 1}):Play()
		TS:Create(E2.Fan.Blur2, TweenInfo.new(3), {Transparency = 1}):Play()
		
		TS:Create(E1.Motor, TweenInfo.new(5), {MaxVelocity = 0}):Play()
		TS:Create(E2.Motor, TweenInfo.new(5), {MaxVelocity = 0}):Play()
	end
end)

Stats_:GetAttributeChangedSignal("Throttle"):Connect(animate)]]></ProtectedString>
