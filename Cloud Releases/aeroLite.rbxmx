				<Item class="Script" referent="RBXC361E1832DA8404EB3D96070A8DBD16D">
					<Properties>
						<ProtectedString name="Source"><![CDATA[-- [ Settings ] --
local weight = nil -- Set nil if you don't want to customize it.
local setAllMassless = false --[[ Set all parts massless. USE THIS WITH CAUTION!

- Recommendation: weight = number * workspace.Gravity
- Because weight = mass x gravity

Unit Conversion:
- 1 Roblox Mass Unit (RMU) is equal to 21.952 kilogram (kg) or 2.205 pounds (lbs).
- Divide by desired unit to convert from RMU.
- Round the number for readability. It doesn't have to be exact.
- Example:
	> kg = number /22 * workspace.Gravity
	> lbs = number /2.2 * workspace.Gravity

]]

task.wait(2)

local weightBlock = script.Parent
local model = weightBlock.Parent

-- Cancel if no customization needed.
if weight == nil then return end

-- Attribute allows you to adjust weight in-game so you can make a mod that simulates payload and such.
weightBlock:SetAttribute("Weight", weight)

if setAllMassless == true then
	for _, part in (model:GetDescendants()) do
		if part:IsA("BasePart") and part ~= weightBlock then
			part.Massless = true
		end
	end
end

weightBlock.Massless = false -- Force massless off in case you accidentally set it on.

local function setMass()
	local size = weightBlock.Size
	local volume = size.X * size.Y * size.Z
	local density = weightBlock.CurrentPhysicalProperties.Density
	
	local currentMass = volume * density
	local multiplier = weight/currentMass
	
	weightBlock.CustomPhysicalProperties = PhysicalProperties.new(
		weightBlock.CurrentPhysicalProperties.Density * multiplier,
		weightBlock.CurrentPhysicalProperties.Friction,
		weightBlock.CurrentPhysicalProperties.Elasticity,
		weightBlock.CurrentPhysicalProperties.FrictionWeight,
		weightBlock.CurrentPhysicalProperties.ElasticityWeight,
		weightBlock.CurrentPhysicalProperties.AcousticAbsorption
	)
end

setMass() -- Initialize

weightBlock:GetAttributeChangedSignal("Weight"):Connect(function()
	-- Update weight
	weight = weightBlock:GetAttribute("Weight")
	setMass()
end)
]]></ProtectedString>
