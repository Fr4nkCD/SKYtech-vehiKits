				<Item class="Script" referent="RBX1F39981D494048309556B3B5AD0BCFA0">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--[[

<< Animation Kit by SKYtech >>
Create motors and animate vehicles easily.

]]
local animation = script.Parent -- A folder that contains moving parts for easier navigation.
local main = script.Parent.Parent.Main.Main -- A part that holds all motors. (ie. plane kit's main part)

function createWeld(x, y)
	local weld = Instance.new("Weld")
	weld.Part0 = x
	weld.Part1 = y
	weld.C0 = x.CFrame:ToObjectSpace(y.CFrame)
	weld.Parent = y
end

function setup(part, weldPart, maxVelocity : number, startAngle : number)
	local mainPart = part:WaitForChild("Main")
	local pivot = mainPart:Clone()
	pivot.Name = "Pivot"
	pivot.Parent = part
	createWeld(weldPart, pivot)
	
	local motor = Instance.new("Motor6D", part)
	motor.Name = "Motor"
	motor.Part0 = pivot
	motor.Part1 = mainPart
	motor.MaxVelocity = maxVelocity or 0
	
	for _, p in (part:GetDescendants()) do
		if p:IsA("BasePart") then
			if p ~= pivot then
				createWeld(mainPart, p)
			end
			p.Anchored = false
		end
	end
	
	motor.DesiredAngle = startAngle or 0
	motor.CurrentAngle = startAngle or 0
end

----- Setup here -----
--< setup(GroupParts, WeldPart, MaxVelocity, StartAngle) >--
setup(animation.Engines.E1, main)
setup(animation.Engines.E2, main)
animation.Engines.E1.Motor.DesiredAngle = math.huge
animation.Engines.E2.Motor.DesiredAngle = math.huge

setup(animation.VTOL_Lids.L1, main, 0.015)
setup(animation.VTOL_Lids.L2, main, 0.015)
setup(animation.VTOL_Lids.L3, main, 0.015)
setup(animation.VTOL_Lids.L4, main, 0.015)

setup(animation.VTOL_Lids.R1, main, 0.015)
setup(animation.VTOL_Lids.R2, main, 0.015)
setup(animation.VTOL_Lids.R3, main, 0.015)
setup(animation.VTOL_Lids.R4, main, 0.015)

script:Destroy()]]></ProtectedString>
