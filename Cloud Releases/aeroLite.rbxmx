					<Item class="Script" referent="RBX57306F04FC17424F8B6872295E3BD3A6">
						<Properties>
							<ProtectedString name="Source"><![CDATA[task.wait(math.random(0, 10)/10)

local SKYtechSystems = game:GetService("ReplicatedStorage"):WaitForChild("SKYtech Systems", 2)
local Modules = if SKYtechSystems then SKYtechSystems:WaitForChild("Modules", 2) else nil
local aeroLite = if Modules then Modules:WaitForChild("aeroLite", 3) else nil

if not aeroLite then
	error("Couldn't load the VTOL system: aeroLite not found.")
end

local rotorLite = if Modules then Modules:WaitForChild("rotorLite", 1) else nil

local aircraft = script.Parent.Parent.Parent
local stateWrapper = aircraft:WaitForChild("System")
local pilot = stateWrapper.Handler.Pilot
local Stats_ = script.Parent.Parent.Stats

local backupModules = script.BackupModules
local backupBridge = backupModules.VTOL_Bridge
local backupFlightPhysics = backupModules.VTOL_FlightPhysics

-- Clone a backup bridge module into the aeroLite module.
if aeroLite:FindFirstChild("VTOL_Bridge") then
	backupBridge:Destroy()
else
	task.wait(0.5) 
	local clone = backupBridge:Clone()
	clone.Parent = aeroLite
	VTOLmodule = clone
end

if not rotorLite then
	-- Clone a backup flight physics module into the aeroLite if the rotorLite is not found.
	if aeroLite:FindFirstChild("VTOL_FlightPhysics") then
		backupFlightPhysics:Destroy()
	else
		task.wait(0.5) 
		local clone = backupFlightPhysics:Clone()
		clone.Parent = aeroLite
		VTOLmodule = clone
	end
end

-- Force a brief yield to ensure the newly parented module is registered in the engine
task.wait(0.5)

local core = require(aeroLite:WaitForChild("VTOL_Bridge"))
core:Initialize(aircraft)

local moduleState = core:GetState(aircraft)

Stats_:SetAttribute("VTOL/Active", false)
Stats_:SetAttribute("VTOL/Percent", 0)

Stats_:GetAttributeChangedSignal("Throttle"):Connect(function()
	Stats_:SetAttribute("Collective", Stats_:GetAttribute("Throttle"))
end)

local RS = game:GetService("RunService")
local serverRun
local speed = 0
local clockSpeed = 1 / 10 -- Hz

function checkPilot()
	if serverRun then serverRun:Disconnect() end
	serverRun = nil

	core:Reset(aircraft)

	if pilot.Value == nil or stateWrapper:GetAttribute("ClientControlled") == false then
		serverRun = RS.Heartbeat:Connect(function(dt)
			speed += dt
			if speed >= clockSpeed then

				local states = moduleState.System
				states.Collective = Stats_:GetAttribute("Collective")
				states.Percent = Stats_:GetAttribute("VTOL/Percent")/100

				local motion = Stats_:GetAttribute("Motion")
				states.Roll = motion.X
				states.Pitch = motion.Y
				states.Yaw = motion.Z

				core:Update(aircraft, speed, false)

				speed = 0
			end
		end)
	end
end checkPilot()

pilot.Changed:Connect(checkPilot)
stateWrapper:GetAttributeChangedSignal("Client_Controlled"):Connect(checkPilot)

script.Update.OnServerEvent:Connect(function(player, active, percent)
	Stats_:SetAttribute("VTOL/Active", active)
	Stats_:SetAttribute("VTOL/Percent", percent)
end)]]></ProtectedString>
