					<Item class="Script" referent="RBX401FD01B55594F8B99BA88DE04EE1AC7">
						<Properties>
							<ProtectedString name="Source"><![CDATA[--[[

<< Copilot System by SKYtech >>

This allows 2 pilots to switch the control between each other during flight.

* To deactivate UI objects when switching, add a tag called "SKYtech_System".
* To exclude UI objects from a copilot, add a tag called "PilotOnly".
* The script will automatically disable UI objects that are detectable by the tags you apply.
* The UI object can be anything such as Frame, TextLabel, LocalScript.
(must have either Visible or Enabled property).

]]
task.wait(1)
local controlMode = 1 -- 0 none, 1 pilot, 2 copilot

local pilot = nil
local copilot = nil
local copilotGui = nil
local copilotSeat = script.Parent.Parent.CopilotSeat
local pilotSeat = script.Parent.Parent.PilotSeat
local players = game:GetService("Players")

local systemModule = script.Parent.Parent.Parent:WaitForChild("System") -- aeroLite System
local system = require(systemModule)
local handler = systemModule:WaitForChild("Handler")
local gui_ = handler:WaitForChild("aeroLite_System")
local Stats_ = script.Parent.Parent.Stats

local mainPilot = handler.Pilot
local license = handler.License

local collectionService = game:GetService("CollectionService")
local switchReady = true

function enableGui(gui: ScreenGui, enabled: boolean)
	-- Disable/enable main UI components for the copilot.
	for _, v in (collectionService:GetTagged("SKYtech_System")) do
		if not v:IsDescendantOf(gui) then continue end
		if v:IsA("GuiObject") then
			v.Visible = enabled
		elseif v:IsA("BaseScript") then
			v.Enabled = enabled
		end
	end
	
	-- Delete critial components from the copilot.
	for _, v in (collectionService:GetTagged("PilotOnly")) do
		if v:IsDescendantOf(gui) then
			v:Destroy()
		end
	end
end

function giveAccess(player: Player)
	copilot = player
	script:SetAttribute("HasCopilot", true)
	copilotGui = copilotGui and copilotGui or gui_:Clone()
	copilotGui.Parent = copilot.PlayerGui
	-----------------------------------------------------
	if mainPilot.Value and mainPilot.Value ~= copilot then
		enableGui(copilotGui, false)
		return
	elseif mainPilot.Value == copilot then
		enableGui(copilotGui, true)
	end
	-----------------------------------------------------
	mainPilot.Value = copilot
	controlMode = 2
	task.wait(0.5)
	license.Value = license.Value and license.Value or handler.aeroLite_License:Clone()
	license.Value.Parent = copilot.PlayerGui
	Stats_:SetAttribute("Motion", Vector3.zero)
	system.Brake = 0
	system:Reset()
end

function revokeAccess()
	if copilot then
		copilot = nil
		script:SetAttribute("HasCopilot", false)
	end
	if copilotGui then copilotGui:Destroy() end
	copilotGui = nil
	returnToPilot()
	Stats_:SetAttribute("Motion", Vector3.zero)
	system.Brake = 0
	system:Reset()
end

function returnToPilot() -- Return pilot the access if copilot exits.
	if not mainPilot.Value then return end
	if pilot then
		mainPilot.Value = pilot
		controlMode = 1
		local pilotGui = pilot.PlayerGui:FindFirstChild(gui_.Name)
		if pilotGui then enableGui(pilotGui, true) end
		if license.Value then license.Value.Parent = pilot.PlayerGui end
		if not copilotSeat:IsGrounded() then copilotSeat:SetNetworkOwner(nil) end
	else
		mainPilot.Value = nil
		controlMode = 0
		if license.Value then license.Value:Destroy() end
		license.Value = nil
	end
	script:SetAttribute("Mode", controlMode)
end

function switchPilot(pilotGui) -- Switch between two pilots.
	if controlMode == 1 then
		controlMode = 2
		mainPilot.Value = copilot
		license.Value.Parent = copilot.PlayerGui
		enableGui(pilotGui, false)
		enableGui(copilotGui, true)
	elseif controlMode == 2 then
		controlMode = 1
		mainPilot.Value = pilot
		license.Value.Parent = pilot.PlayerGui
		enableGui(pilotGui, true)
		enableGui(copilotGui, false)
	end
	script:SetAttribute("Mode", controlMode)
	if not copilotSeat:IsGrounded() then copilotSeat:SetNetworkOwner(nil) end
end

copilotSeat:GetPropertyChangedSignal("Occupant"):Connect(function()
	local humanoid = copilotSeat.Occupant
	if humanoid then
		local player = players:GetPlayerFromCharacter(humanoid.Parent)
		if player then
			giveAccess(player)
		end
	else
		revokeAccess()
	end
end)

pilotSeat:GetPropertyChangedSignal("Occupant"):Connect(function()
	local humanoid = pilotSeat.Occupant
	if humanoid then
		local player = players:GetPlayerFromCharacter(humanoid.Parent)
		if player then
			pilot = player
		end
	else
		pilot = nil
	end
	script:SetAttribute("HasPilot", pilot and true or false)
end)

mainPilot.Changed:Connect(function()
	if mainPilot.Value and mainPilot.Value ~= copilot then
		returnToPilot()
	end
	if copilot then
		giveAccess(copilot)
	end
end)

script.Switch.OnServerEvent:Connect(function(player : Player)
	if not switchReady then return end
	if (controlMode < 2 and player ~= pilot) or (controlMode == 2 and player ~= pilot and player ~= copilot) then return end
	local pilotGui = player.PlayerGui:FindFirstChild(gui_.Name)
	local copilotGui = pilotGui
	if not pilotGui or not copilotGui then return end
	if controlMode == 0 then return end
	if controlMode > 0 and not pilot or not copilot then return end
	script.Switch:FireClient(pilot)
	script.Switch:FireClient(copilot)
	task.spawn(function()
		switchReady = false
		task.wait(10)
		switchReady = true
	end)
	task.wait(5)
	if not license.Value then return end
	if controlMode == 0 then return end
	if controlMode > 0 and not pilot or not copilot then return end
	switchPilot(pilotGui)
	-- Double check to make sure no pilots leave during the process.
end)]]></ProtectedString>
							<bool name="Disabled">false</bool>
							<Content name="LinkedSource"><null></null></Content>
							<token name="RunContext">0</token>
							<string name="ScriptGuid">{5CEC6AD2-F283-40AD-961A-F61500732EF4}</string>
							<BinaryString name="AttributesSerialize">AwAAAAoAAABIYXNDb3BpbG90AwAIAAAASGFzUGlsb3QDAAQAAABNb2RlBQAAAAA=</BinaryString>
							<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
							<bool name="DefinesCapabilities">true</bool>
							<string name="Name">Copilot_System</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
						<Item class="RemoteEvent" referent="RBXB01F06740FD345F293D6D1C1E7038646">
							<Properties>
								<BinaryString name="AttributesSerialize"></BinaryString>
								<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
								<bool name="DefinesCapabilities">true</bool>
								<string name="Name">Switch</string>
								<int64 name="SourceAssetId">-1</int64>
								<BinaryString name="Tags"></BinaryString>
							</Properties>
						</Item>
					</Item>
					<Item class="Script" referent="RBX1D03385863A84F75B53F69A56A076678">
						<Properties>
							<ProtectedString name="Source"><![CDATA[--[ Adjust the group ID/rank in the "Settings" module ]--

local Settings = script.Parent.Parent.Parent:WaitForChild("Settings")
local Players = game:GetService("Players")

local seats = { -- You can add more seats such as FO seat.
	script.Parent.Parent:WaitForChild("PilotSeat"),
}

for _, seat : Seat in pairs(seats) do
	seat:GetPropertyChangedSignal("Occupant"):Connect(function()
		if Settings:GetAttribute("Modifications/GroupLock") == true then
			local humanoid = seat.Occupant
			if humanoid then
				local player = Players:GetPlayerFromCharacter(humanoid.Parent)
				if player and player:GetRankInGroupAsync(Settings:GetAttribute("Modifications/GroupID")) < Settings:GetAttribute("Modifications/GroupRank") then
					local defaultUseJumpPower = humanoid.UseJumpPower
					local defaultJumpPower = humanoid.JumpPower
					task.wait(0.25)
					humanoid.UseJumpPower = defaultUseJumpPower
					humanoid.JumpPower = defaultJumpPower
					humanoid.Jump = true
				end
			end
		end
	end)
end]]></ProtectedString>
							<bool name="Disabled">false</bool>
							<Content name="LinkedSource"><null></null></Content>
							<token name="RunContext">0</token>
							<string name="ScriptGuid">{1C5E1860-5767-4DC8-995C-F14875646A9B}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
							<bool name="DefinesCapabilities">true</bool>
							<string name="Name">Group_Lock</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
					</Item>
					<Item class="Script" referent="RBX39F3521E94CF4BADA82B29794D17BCA4">
						<Properties>
							<ProtectedString name="Source"><![CDATA[----- Settings -----
local idle_BasePitch, idle_MaxPitch, idle_Volume = 0.7, 2, 1
local buzzsaw_BasePitch, buzzsaw_MaxPitch, buzzsaw_Volume = 1, 2.5, 0.5
--------------------

local Stats_ = script.Parent.Parent:WaitForChild("Stats")

local sound_Attachment = script.Parent.Parent:WaitForChild("Main"):WaitForChild("Sound_Attachment")

local idle_Values = Vector2.new()
local buzzsaw_Values = Vector2.new()

sound_Attachment.Idle:Play()
sound_Attachment.Idle.Volume = 0
sound_Attachment.Buzzsaw:Play()
sound_Attachment.Buzzsaw.Volume = 0

game:GetService("RunService").Heartbeat:Connect(function()
	local toggle = 0
	if Stats_:GetAttribute("Active") == true then toggle = 1 else toggle = 0 end
	
	local throttle = Stats_:GetAttribute("Throttle")
	
	idle_Values = idle_Values:Lerp(Vector2.new( idle_BasePitch + ((throttle * (idle_MaxPitch - idle_BasePitch)) * toggle) , (buzzsaw_Volume * (1 - throttle)) * toggle ), 0.03)
	buzzsaw_Values = buzzsaw_Values:Lerp(Vector2.new( buzzsaw_BasePitch + ((throttle * (buzzsaw_MaxPitch - buzzsaw_BasePitch)) * toggle) , buzzsaw_Volume * (throttle * toggle) ), 0.03)
	
	sound_Attachment.Idle.PlaybackSpeed = idle_Values.X
	sound_Attachment.Idle.Volume = idle_Values.Y
	
	sound_Attachment.Buzzsaw.PlaybackSpeed = buzzsaw_Values.X
	sound_Attachment.Buzzsaw.Volume = buzzsaw_Values.Y/2

end)]]></ProtectedString>
