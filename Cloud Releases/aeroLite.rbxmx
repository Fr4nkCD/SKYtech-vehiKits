								<Item class="LocalScript" referent="RBXBFC732CBB8674DFD94D0B0F8748C4BF1">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local remote = script.Parent.Parent:WaitForChild("Remote").Value
local count, t1, t2, dt = 0, 0, 0, 0
script.Parent.Visible = false
remote.OnClientEvent:Connect(function()
	script.Parent.Visible = true
	count = 5
	t1 = os.clock()
	t2 = t1
	while count > 0 do
		t1 = os.clock()
		dt = t1 - t2
		t2 = t1
		count -= dt
		script.Parent.Text = "Switching pilot in "..math.ceil(count)
		task.wait()
	end
	script.Parent.Visible = false
end)]]></ProtectedString>
