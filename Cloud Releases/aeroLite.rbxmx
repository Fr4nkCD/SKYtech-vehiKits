							<Item class="LocalScript" referent="RBX5CE7FD3E86C84731824A3C623EE8C1AD">
								<Properties>
									<ProtectedString name="Source"><![CDATA[-- Reset player's camera and mouse states.
local player = game:GetService("Players").LocalPlayer
local mouse = player:GetMouse()
local camera = workspace.CurrentCamera
local defaultMaxZoomDistance = game:GetService("StarterPlayer").CameraMaxZoomDistance

local aircraft = script.Parent.Parent:WaitForChild("Aircraft").Value
local pilot = aircraft:WaitForChild("System").Handler.Pilot

local copilotInfo = script.Parent
local mainScript = copilotInfo:WaitForChild("Remote").Value.Parent
local switchButton = copilotInfo:WaitForChild("Switch")

function toggleButton()
	switchButton.Visible = ((pilot.Value == player or mainScript:GetAttribute("Mode") == 2) and
		mainScript:GetAttribute("HasPilot") and mainScript:GetAttribute("HasCopilot")) and true or false
end toggleButton()

pilot.Changed:Connect(function()
	player.CameraMaxZoomDistance = defaultMaxZoomDistance
	camera.CameraSubject = player.Character
	camera.CameraType = Enum.CameraType.Custom
	mouse.Icon = ""
	toggleButton()
end)

mainScript.AttributeChanged:Connect(toggleButton)]]></ProtectedString>
