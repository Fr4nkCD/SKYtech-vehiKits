							<Item class="LocalScript" referent="RBXF05B59073CE347108480A5407D79D3D2">
								<Properties>
									<ProtectedString name="Source"><![CDATA[local BASE_WIDTH = 1280
local MIN_SCALE, MAX_SCALE = 0.7, 1.5

local camera = workspace.CurrentCamera
local UIScale = script.Parent

UIScale.Scale = math.clamp(camera.ViewportSize.X/BASE_WIDTH, MIN_SCALE, MAX_SCALE)

camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
	UIScale.Scale = math.clamp(camera.ViewportSize.X/BASE_WIDTH, MIN_SCALE, MAX_SCALE)
end)]]></ProtectedString>
