							<Item class="LocalScript" referent="RBX80ECFA2A27264BAFA9FF3E8156913C6B">
								<Properties>
									<ProtectedString name="Source"><![CDATA[------------ Mobile Control Module ------------
local UIS = game:GetService("UserInputService")
if UIS:GetLastInputType() ~= Enum.UserInputType.Touch then
	script.Parent:Destroy()
	return
end

local camera = workspace.CurrentCamera

local gui = script.Parent.Parent
local aircraft = gui.Aircraft.Value
local updateEvent = aircraft.System.Update

local Settings = aircraft.Settings
local main = aircraft.Main
local mainPart = main.Main
local pilotSeat = main.PilotSeat

local Stats_ = main.Stats
local Mods = main.Mods

local controller = gui.Controller
local mobile_Panel = script.Parent

local onControl = false
local throttleInput = Stats_:GetAttribute("Throttle")
local desiredThrottle = throttleInput

controller:SetAttribute("Custom_Control", true)
controller:SetAttribute("Throttle", Stats_:GetAttribute("Throttle"))

local TS = game:GetService("TweenService")
local onColor = Color3.fromRGB(40, 216, 49)
local offColor = Color3.fromRGB(232, 43, 55)
local blackColor = Color3.fromRGB(48, 48, 48)

----------------------------------------------------------

function checkInput(pad, input)
	local padPos = pad.AbsolutePosition
	local padSize = pad.AbsoluteSize
	local touchPos = input.Position

	local isInside = touchPos.X >= padPos.X and touchPos.X <= (padPos.X + padSize.X) and
		touchPos.Y >= padPos.Y and touchPos.Y <= (padPos.Y + padSize.Y)
	
	return isInside
end

mobile_Panel.Buttons.Control.MouseButton1Click:Connect(function() -- Take Control
	if not onControl then
		onControl = true
		camera.CameraType = Enum.CameraType[Settings:GetAttribute("FlightControls/CameraType")]
		mobile_Panel.Thumbstick.Visible = true
		mobile_Panel.Buttons.Control.BackgroundColor3 = onColor
	else
		onControl = false
		camera.CameraType = Enum.CameraType.Custom
		mobile_Panel.Thumbstick.Visible = false
		mobile_Panel.Buttons.Control.BackgroundColor3 = offColor
		
		controller:SetAttribute("Roll", 0)
		controller:SetAttribute("Pitch", 0)
	end
end)

do -- Throttle
	local throttle_Panel = mobile_Panel.Throttle
	local knob = throttle_Panel.Knob
	local activeInput = nil
	
	local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
	local showKnob = TS:Create(knob, tweenInfo, 
		{BackgroundTransparency = 0.25})
	local hideKnob = TS:Create(knob, tweenInfo, 
		{BackgroundTransparency = 1})
	
	throttle_Panel.InputBegan:Connect(function(input, processed)
		if processed or input.UserInputType ~= Enum.UserInputType.Touch then return end
		
		if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
			activeInput = input
			showKnob:Play()
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == activeInput then
			local knobRatio = math.clamp((input.Position.Y - throttle_Panel.AbsolutePosition.Y)/throttle_Panel.AbsoluteSize.Y, 0, 1)
			knob:TweenPosition(UDim2.new(0.5, 0, knobRatio, 0), "Out", "Quad", 0.15, true)
			knob.AnchorPoint = Vector2.new(0.5, 0.5 + (knobRatio * 0.25))
			desiredThrottle = 1 - knobRatio
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input == activeInput then
			activeInput = nil
			hideKnob:Play()
		end
	end)

end

do -- Thumbstick
	local thumbstick = mobile_Panel.Thumbstick
	local knob = thumbstick.Knob
	local activeInput = nil
	
	thumbstick.InputBegan:Connect(function(input, processed)
		if processed or input.UserInputType ~= Enum.UserInputType.Touch then return end
		
		if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
			activeInput = input
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == activeInput then
			local xRatio = (input.Position.X - thumbstick.AbsolutePosition.X) / thumbstick.AbsoluteSize.X
			local yRatio = (input.Position.Y - thumbstick.AbsolutePosition.Y) / thumbstick.AbsoluteSize.Y

			local dx = xRatio - 0.5
			local dy = yRatio - 0.5

			local dist = math.sqrt(dx * dx + dy * dy)
			if dist > 0.5 then
				local scale = 0.5 / dist
				dx = dx * scale
				dy = dy * scale
			end

			local newX = dx + 0.5
			local newY = dy + 0.5
			knob:TweenPosition(UDim2.new(newX, 0, newY, 0), "Out", "Quad", 0.15, true)
			
			controller:SetAttribute("Roll", dx * -2) 
			controller:SetAttribute("Pitch", dy * 2)
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input == activeInput then
			activeInput = nil
			knob:TweenPosition(UDim2.new(0.5, 0, 0.5, 0), "Out", "Quad", 0.1, true)
			controller:SetAttribute("Roll", 0) 
			controller:SetAttribute("Pitch", 0)
		end
	end)
	
end

do -- Yaw
	local yaw = mobile_Panel.Yaw
	local knob = yaw.Knob
	local activeInput = nil
	
	yaw.InputBegan:Connect(function(input, processed)
		if processed or input.UserInputType ~= Enum.UserInputType.Touch then return end
		
		if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
			activeInput = input
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == activeInput then
			local knobRatio = math.clamp((input.Position.X - yaw.AbsolutePosition.X)/yaw.AbsoluteSize.X, 0, 1)
			knob:TweenPosition(UDim2.new(0.2 + (knobRatio * 0.6), 0, 0.5, 0), "Out", "Quad", 0.15, true)
			controller:SetAttribute("Yaw", (knobRatio - 0.5) * -2)
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input == activeInput then
			activeInput = nil
			knob:TweenPosition(UDim2.new(0.5, 0, 0.5, 0), "Out", "Quad", 0.15, true)
			controller:SetAttribute("Yaw", 0)
		end
	end)
	
end

do -- Engine
	if Settings:GetAttribute("FlightControls/Engine") == "nil" then mobile_Panel.Buttons.Engine.Visible = false end

	mobile_Panel.Buttons.Engine.MouseButton1Click:Connect(function()
		updateEvent:FireServer("Active")
	end)

	local function updateButton()
		mobile_Panel.Buttons.Engine.BackgroundColor3 = Stats_:GetAttribute("Active") == true and onColor or offColor
	end updateButton()

	Stats_:GetAttributeChangedSignal("Active"):Connect(updateButton)
end

do -- Brake
	local brake = mobile_Panel.Buttons.Brake
	local activeInput = nil
	
	brake.InputBegan:Connect(function(input, processed)
		if processed or input.UserInputType ~= Enum.UserInputType.Touch then return end

		if input.UserInputState == Enum.UserInputState.Begin and not activeInput then
			activeInput = input
			controller:SetAttribute("Brake", controller:GetAttribute("Brake") + 1)
			brake.BackgroundColor3 = offColor
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input == activeInput then
			activeInput = nil
			controller:SetAttribute("Brake", 0)
			brake.BackgroundColor3 = blackColor
		end
	end)
end

do -- Landing Gear
	local landingGear = Mods:FindFirstChild("LandingGear")
	if landingGear then
		if landingGear:GetAttribute("Available") == true then
			mobile_Panel.Buttons.LandingGear.MouseButton1Click:Connect(function()
				landingGear.Remote:FireServer()
			end)

			local function updateButton()
				mobile_Panel.Buttons.LandingGear.BackgroundColor3 = landingGear:GetAttribute("Toggle") == true and onColor or offColor
			end updateButton()

			landingGear:GetAttributeChangedSignal("Toggle"):Connect(updateButton)
		else
			mobile_Panel.Buttons.LandingGear.Visible = false
		end
	else
		mobile_Panel.Buttons.LandingGear.Visible = false
	end
end

Settings:GetAttributeChangedSignal("AttitudeControls/Advanced"):Connect(function() -- Enable yaw (if it's advanced)
	if Settings:GetAttribute("AttitudeControls/Advanced") == true then
		mobile_Panel.Yaw.Visible = true
	else
		mobile_Panel.Yaw.Visible = false
		controller:SetAttribute("Yaw", 0)
	end
end)

----------------------------------------------------------

do -- Setup
	mobile_Panel.Throttle.Knob.BackgroundTransparency = 1
	mobile_Panel.Throttle.BackgroundTransparency = 1
	mobile_Panel.Throttle.Note.Visible = false
	mobile_Panel.Thumbstick.Visible = false
	
	if Settings:GetAttribute("AttitudeControls/Advanced") == true then
		mobile_Panel.Yaw.Visible = true
	else
		mobile_Panel.Yaw.Visible = false
		controller:SetAttribute("Yaw", 0)
	end
	
	if Settings:GetAttribute("FlightControls/ToggleControl") == "nil" then
		-- Force control if there's no keykind
		onControl = true
		camera.CameraType = Enum.CameraType[Settings.Flight_Controls.CameraType.Value]
		mobile_Panel.Thumbstick.Visible = true
		mobile_Panel.Buttons.Control.Visible = false
	end
end

game:GetService("RunService").Heartbeat:Connect(function(dt) -- Main
	-- Send inputs to the kit controller attributes.
	
	if Stats_:GetAttribute("Active") == true then
		local throttleChange = math.clamp((desiredThrottle - throttleInput)/0.01, -1, 1)
		throttleInput = math.clamp(throttleInput + (throttleChange * Settings:GetAttribute("FlightControls/ThrottleIncrement") * dt), 0, 1)
		controller:SetAttribute("Throttle", throttleInput)
	else
		desiredThrottle = 0
		throttleInput = 0
		controller:SetAttribute("Throttle", 0)
	end
end)]]></ProtectedString>
