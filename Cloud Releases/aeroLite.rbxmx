									<ProtectedString name="Source"><![CDATA[local gui = script.Parent.Parent
local aircraft = gui.Aircraft.Value

local main_ = aircraft.Main
local mainPart = main_.Main

local Settings = aircraft.Settings
local Stats_ = main_.Stats
local system_ = aircraft.System

local panel = script.Parent
local controller = gui.Controller
local control_Handler = gui.Control_Handler

-------------------------------------------------------------

local function getRoll(CF)
	local CFRight = CF * CFrame.Angles(0, math.rad(90), 0)
	local noRollRight = CFrame.new(CF.p, (CF.p + CF.LookVector)) * CFrame.Angles(0, math.rad(90), 0)
	local CFDiff = CFRight:ToObjectSpace(noRollRight)
	return math.atan2(CFDiff.LookVector.Y, CFDiff.LookVector.Z) % (math.pi * 2) + math.pi
end

game:GetService("RunService"):BindToRenderStep("Update Flight Instruments", Enum.RenderPriority.Camera.Value + 1, function()
	local physicsScale = Settings:GetAttribute("Advanced/PhysicsScale")
	local _maxSpeed = Settings:GetAttribute("AircraftStatistics/MaxSpeed")
	local _stallSpeed = Settings:GetAttribute("AircraftStatistics/StallSpeed")
	local _maxAltitude = Settings:GetAttribute("AircraftStatistics/MaxAltitude")
	local _airbrake = Settings:GetAttribute("AircraftStatistics/Airbrake")
	local changedbyAltitude = Settings:GetAttribute("AircraftStatistics/ChangedbyAltitude")
	
	local velocity = mainPart.AssemblyLinearVelocity/physicsScale
	local altitude = mainPart.Position.Y/physicsScale
	
	local isActive = Stats_:GetAttribute("Active") == false
	local flying = system_:GetAttribute("Flying") == true
	local stalling = system_:GetAttribute("Stalling") == true
	
	local isFuelOn = Settings:GetAttribute("FuelSystem/Enabled") == true
	local fuel = Stats_:GetAttribute("Fuel")
	
	------------------------------------------------------------------------
	
	panel.Heading.Value.Text = math.round(-mainPart.Orientation.Y%360).."°"
	panel.Speed.Value.Text = math.round(velocity.Magnitude)
	panel.Altitude.Value.Text = math.round(altitude)
	panel.Throttle.Main.Position = UDim2.new(0.5, 0, 1 - control_Handler.Throttle.Size.Y.Scale, 0)
	panel.Throttle.Main.Text = math.round(control_Handler.Throttle.Size.Y.Scale * 100)
	panel.Throttle.Bar.Speed.Size = UDim2.new(1, 0, math.min(velocity.Magnitude/_maxSpeed, 1))
	
	local VSI = math.sin(math.clamp(-velocity.Y/20, -1.5, 1.5))/2
	panel.Altitude.VerticalSpeed.Arrow.Position = UDim2.new(0, 15, 0.5 + VSI, 0)
	panel.Altitude.VerticalSpeed.Arrow.Value.Text = (math.round(velocity.Y * 10)/10).." sps"
	
	local bankAngle = -math.deg(getRoll(mainPart.CFrame)) + 360
	local stallSpeedChangedbyAltitude = changedbyAltitude and (_maxSpeed - _stallSpeed) * math.clamp((altitude/_maxAltitude) + math.clamp((altitude - _maxAltitude)/10, 0, 1), 0, 1) or 0
	local stallSpeed = _stallSpeed + (math.abs(bankAngle/180) * (_stallSpeed/3)) + stallSpeedChangedbyAltitude - mainPart.CFrame:VectorToObjectSpace(workspace.GlobalWind).Z
	panel.Throttle.Bar.StallLine.Position = UDim2.new(0, 0, 1 - math.clamp(stallSpeed/_maxSpeed, 0, 1))
	panel.EngineOff.Visible = isActive or fuel < 10
	if fuel > 0 then
		if fuel > 10 then
			panel.EngineOff.Text = "Engine Off"
		else
			panel.EngineOff.Text = not isActive and "Low Fuel" or "Engine Off"
		end
	else
		panel.EngineOff.Text = "Out of Fuel"
	end
	panel.Stall.Visible = stalling
	panel.Brake.Visible = controller:GetAttribute("Brake") > 0
		and (_airbrake or (not _airbrake and not flying and not stalling))
	
	panel.Fuel.Visible = isFuelOn
	if isFuelOn then
		panel.Fuel.Amount.Size = UDim2.new(1, 0, fuel/100, 0)
	end
end)

panel.Stall:GetPropertyChangedSignal("Visible"):Connect(function()
	if panel.Stall.Visible then
		panel.Stall.Warning:Play()
	else
		panel.Stall.Warning:Stop()
	end
end)
]]></ProtectedString>
