AFNLWXRlY2hfU3lzdGVtAwEIAAAAVGhyb3R0bGUGAAAAAAAAAAADAAAAWWF3BgAAAAAAAAAA
]]></BinaryString>
										<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
										<bool name="DefinesCapabilities">true</bool>
										<string name="Name">Controller</string>
										<int64 name="SourceAssetId">-1</int64>
										<BinaryString name="Tags">U0tZdGVjaF9TeXN0ZW0=</BinaryString>
									</Properties>
								</Item>
								<Item class="RemoteEvent" referent="RBX0C358039483241159F97A0C2F81D9EF5">
									<Properties>
										<BinaryString name="AttributesSerialize"></BinaryString>
										<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
										<bool name="DefinesCapabilities">true</bool>
										<string name="Name">Activate</string>
										<int64 name="SourceAssetId">-1</int64>
										<BinaryString name="Tags"></BinaryString>
									</Properties>
									<Item class="Script" referent="RBX6D8965B864224B9D98E0E4373BCC03D1">
										<Properties>
											<ProtectedString name="Source"><![CDATA[local active = script.Parent.Parent
local Stats_ = active.Parent

script.Parent.OnServerEvent:Connect(function(player)
	if player.PlayerGui:FindFirstChild("aeroMini_License") == nil then return end
	active.Value = not active.Value
	Stats_:SetAttribute("Active", active.Value)
end)]]></ProtectedString>
											<bool name="Disabled">true</bool>
											<Content name="LinkedSource"><null></null></Content>
											<token name="RunContext">0</token>
											<string name="ScriptGuid">{8A523ED4-597E-43BA-94FC-886350C7610D}</string>
											<BinaryString name="AttributesSerialize"></BinaryString>
											<SecurityCapabilities name="Capabilities">17996771963439872</SecurityCapabilities>
											<bool name="DefinesCapabilities">true</bool>
											<string name="Name">Function</string>
											<int64 name="SourceAssetId">-1</int64>
											<BinaryString name="Tags"></BinaryString>
										</Properties>
