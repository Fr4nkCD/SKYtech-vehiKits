									<Item class="LocalScript" referent="RBX72D4433E5F0E41EB84A2975FDA8412FA">
										<Properties>
											<ProtectedString name="Source"><![CDATA[local gui = script.Parent.Parent.Parent
local aircraft = gui.Aircraft.Value
local Settings = aircraft.Settings

local gamepadPanel = script.Parent.Gamepad

local defaultGuide = gui:FindFirstChild("Control_Guide")
if defaultGuide then
	defaultGuide:Destroy()
end

local Guides = { Left = { DPads = {} }, Right = { DPads = {} } }

local function setupGuide(Type)
	-- Left
	if Guides.Left.DPads.Up then
		Type.Left.DPads.Up.Text = Guides.Left.DPads.Up.." [↑]"
	else
		Type.Left.DPads.Up.Visible = false
	end
	if Guides.Left.DPads.Down then
		Type.Left.DPads.Down.Text = Guides.Left.DPads.Down.." [↓]"
	else
		Type.Left.DPads.Down.Visible = false
	end
	if Guides.Left.DPads.Left then
		Type.Left.DPads.Left.Text = Guides.Left.DPads.Left.." [←]"
	else
		Type.Left.DPads.Left.Visible = false
	end
	if Guides.Left.DPads.Right then
		Type.Left.DPads.Right.Text = Guides.Left.DPads.Right.." [→]"
	else
		Type.Left.DPads.Right.Visible = false
	end

	if Guides.Left.L1 then
		Type.Left.L1.Text = Guides.Left.L1.." <b>[L1]</b>"
	else
		Type.Left.L1.Visible = false
	end
	if Guides.Left.L2 then
		Type.Left.L2.Text = Guides.Left.L2.." <b>[L2]</b>"
	else
		Type.Left.L2.Visible = false
	end
	if Guides.Left.L3 then
		Type.Left.L3.Text = Guides.Left.L3.." <b>[L3]</b>"
	else
		Type.Left.L3.Visible = false
	end
	if Guides.Left.LS then
		Type.Left.LS.Text = Guides.Left.LS.." <b>[LS]</b>"
	else
		Type.Left.LS.Visible = false
	end

	if Guides.Left.Select then
		Type.Left.Select.Text = Guides.Left.Select.." <b>[Select]</b>"
	else
		Type.Left.Select.Visible = false
	end

	-- Right
	if Guides.Right.A then
		Type.Right.A.Text = "<b>[A]</b> "..Guides.Right.A
	else
		Type.Right.A.Visible = false
	end
	if Guides.Right.B then
		Type.Right.B.Text = "<b>[B]</b> "..Guides.Right.B
	else
		Type.Right.B.Visible = false
	end
	if Guides.Right.X then
		Type.Right.X.Text = "<b>[X]</b> "..Guides.Right.X
	else
		Type.Right.X.Visible = false
	end
	if Guides.Right.Y then
		Type.Right.Y.Text = "<b>[Y]</b> "..Guides.Right.Y
	else
		Type.Right.Y.Visible = false
	end

	if Guides.Right.R1 then
		Type.Right.R1.Text = "<b>[R1]</b> "..Guides.Right.R1
	else
		Type.Right.R1.Visible = false
	end
	if Guides.Right.R2 then
		Type.Right.R2.Text = "<b>[R2]</b> "..Guides.Right.R2
	else
		Type.Right.R2.Visible = false
	end
	if Guides.Right.R3 then
		Type.Right.R3.Text = "<b>[R3]</b> "..Guides.Right.R3
	else
		Type.Right.R3.Visible = false
	end
	if Guides.Right.RS then
		Type.Right.RS.Text = "<b>[RS]</b> "..Guides.Right.RS
	else
		Type.Right.RS.Visible = false
	end

	if Guides.Right.Start then
		Type.Right.Start.Text = "<b>[Start]<b/> "..Guides.Right.Start
	else
		Type.Right.Start.Visible = false
	end
end

------------------------------- Automatic Mapping

-- Mapping from KeyCodes to your guide structure
local buttonMap = {
	[Enum.KeyCode.DPadUp] = {side="Left", path={"DPads","Up"}},
	[Enum.KeyCode.DPadDown] = {side="Left", path={"DPads","Down"}},
	[Enum.KeyCode.DPadLeft] = {side="Left", path={"DPads","Left"}},
	[Enum.KeyCode.DPadRight] = {side="Left", path={"DPads","Right"}},

	[Enum.KeyCode.ButtonL1] = {side="Left", path={"L1"}},
	[Enum.KeyCode.ButtonL2] = {side="Left", path={"L2"}},
	[Enum.KeyCode.ButtonL3] = {side="Left", path={"L3"}},
	[Enum.KeyCode.Thumbstick1] = {side="Left", path={"LS"}},
	[Enum.KeyCode.ButtonSelect] = {side="Left", path={"Select"}},

	[Enum.KeyCode.ButtonA] = {side="Right", path={"A"}},
	[Enum.KeyCode.ButtonB] = {side="Right", path={"B"}},
	[Enum.KeyCode.ButtonX] = {side="Right", path={"X"}},
	[Enum.KeyCode.ButtonY] = {side="Right", path={"Y"}},
	[Enum.KeyCode.ButtonR1] = {side="Right", path={"R1"}},
	[Enum.KeyCode.ButtonR2] = {side="Right", path={"R2"}},
	[Enum.KeyCode.ButtonR3] = {side="Right", path={"R3"}},
	[Enum.KeyCode.Thumbstick2] = {side="Right", path={"RS"}},
	[Enum.KeyCode.ButtonStart] = {side="Right", path={"Start"}},
}

-- Loop through all actions & bindings in the context
local inputButtons = {"Up", "Down", "Left", "Right"}

for attrName, keycode in pairs(Settings:GetAttributes()) do
	if attrName:find("FlightControls/Gamepad/") then
		for _, inputInfo in ipairs(inputButtons) do
			if keycode == "nil" then continue end
			local keyName = attrName:gsub("FlightControls/Gamepad/", "")
			local key = Enum.KeyCode[keycode]
			local info = buttonMap[key]
			if info then  -- Check if the key exists in the mapping
				local sideTable = Guides[info.side]
				local current = sideTable
				for i = 1, #info.path - 1 do
					current = current[info.path[i]]
				end
				local direction = attrName:match(inputInfo)
				current[info.path[#info.path]] = keyName:gsub("(%l)(%u)", "%1 %2")..(direction and " "..direction or "")
			end
		end
	end
end

-- Fixed or overriden contexts
Guides.Left.Select = "UI Navigation"
Guides.Left.LS = "Roll & Pitch"
Guides.Left.L2 = "Yaw Left"
Guides.Left.L3 = "Lock Camera"

Guides.Right.RS = "Camera"
Guides.Right.R2 = "Yaw Right"
Guides.Right.R3 = "Camera Cycles"
-------------------------------

setupGuide(gamepadPanel)

--------------------- Extra stuff ---------------------

local function searchGuide(names)
	local collectedGuides = {}
	
	for _, v in (gamepadPanel:GetDescendants()) do
		if v:IsA("TextLabel") then
			for __, name in (names) do
				if v.Text:find(name) then
					table.insert(collectedGuides, v)
				end
			end
		end
	end
	
	return table.unpack(collectedGuides)
end

-------------------------------------------------------

local yawLGuide, yawRGuide, gearGuide = searchGuide({"Yaw Left", "Yaw Right", "Landing Gear"})

-- Toggle yaw guides based on advanced mode
local function checkAdvancedControl()
	if yawLGuide and yawRGuide then
		local advanced = Settings:GetAttribute("AttitudeControls/Advanced") == true
		yawLGuide.Visible = advanced
		yawRGuide.Visible = advanced
	end
end

checkAdvancedControl()
Settings:GetAttributeChangedSignal("AttitudeControls/Advanced"):Connect(checkAdvancedControl)

-- Hide landing gear guide if not available
local landingGear = aircraft.Main.Mods:FindFirstChild("LandingGear")
if not landingGear or (landingGear and landingGear:GetAttribute("Available") == false) then
	if gearGuide then
		gearGuide.Visible = false
	end
end]]></ProtectedString>
