								<Content name="LinkedSource"><null></null></Content>
								<ProtectedString name="Source"><![CDATA[-- aeroMini Flight Physics
-- by SKYtech

local aeroMini = {
	States = {}
}

-- Utilies (math, physics, global variables)
local Utils = require(script.Parent:WaitForChild("VehicleUtils"))

function aeroMini:Initialize(aircraft)
	local main = aircraft.Main
	local mainPart = main.Main

	self.States[aircraft] = {
		System = {
			Throttle = 0,
			Roll = 0,
			Pitch = 0,
			Yaw = 0,
			MousePosition = nil,
			-----------------------
			Boost = 0,
			MinSpeed = 0,
			Speed = 0,
			MotionCFrame = CFrame.new(),
			-----------------------
			Direction = mainPart.CFrame.LookVector * 1e6,
			RollAccumulated = 0,
			RestingAngle = 0,
			CurrentRoll = 0,
			CurrentPitch = 0,
		},
		Settings = {},
		Connections = {},
		Components = {
			StateWrapper = aircraft.System,
			StateUpdateEvent = aircraft.System.Update,
			MainPart = mainPart,
			Motion = mainPart.Motion,
			Thrust = mainPart.Thrust,
			Gravity = mainPart.Gravity,
			BoundSize = nil,
		},
		IgnoredObjects = {aircraft},
		RayFilter = nil,
		Step = 0,
	}

	local state = self.States[aircraft]

	local Settings = aircraft:FindFirstChild("Settings")

	-- Initialize settings.
	for attrName, attrValue in pairs(Settings:GetAttributes()) do
		Utils.UpdateSetting(attrName, attrValue, state.Settings)
	end	

	-- Update legacy value objects on the client side.
	if Utils.IsClient() then
		Utils.SyncLegacyValues(Settings, state.Connections)
	end

	-- Update settings on attribute changed.
	table.insert(state.Connections, Settings.AttributeChanged:Connect(function(attrName)
		local attrValue = Settings:GetAttribute(attrName)
		if attrValue == nil then return end
		Utils.UpdateSetting(attrName, attrValue, state.Settings)
	end))

	state.RayFilter = RaycastParams.new()
	state.RayFilter.FilterType = Enum.RaycastFilterType.Exclude

	local _, boundSize = aircraft:GetBoundingBox()
	state.Components.BoundSize = boundSize

	self:Reset(aircraft)
end

function aeroMini:GetState(aircraft)
	return self.States[aircraft]
end

function aeroMini:Reset(aircraft)
	local state = self.States[aircraft]

	local System = state.System
	local mainPart = state.Components.MainPart
	
	local mainCFrame = mainPart.CFrame
	System.Speed = -mainCFrame:VectorToObjectSpace(mainPart.AssemblyLinearVelocity).Z
	System.MotionCFrame = mainCFrame
	System.Direction = mainCFrame.LookVector * 1e6
end

function aeroMini:Update(aircraft, dt, onClient)	
	local state = self.States[aircraft]

	if not state then return end

	state.Step += dt

	local System = state.System
	local Settings = state.Settings
	local Components = state.Components

	local stateWrapper = Components.StateWrapper
	local stateUpdateEvent = Components.StateUpdateEvent

	local mainPart = Components.MainPart
	local motion = Components.Motion
	local thrust = Components.Thrust
	local gravity = Components.Gravity
	local boundSize = Components.BoundSize
	
	-- Variables that need to be updated every frame.
	local physicsScale = Utils.Max(Settings.Modifications.PhysicsScale or Settings.Advanced.PhysicsScale, 0.001)
	local _stallSpeed = Utils.Max(Settings.AircraftStatistics.StallSpeed * physicsScale, 0.001)
	local _maxAltitude = Utils.Max(Settings.AircraftStatistics.MaxAltitude * physicsScale, 0.001)
	
	local globalWind = workspace.GlobalWind
	local globalGravity = workspace.Gravity
	
	local mainCFrame = mainPart.CFrame
	local trueSpeed = Utils.Abs(System.Speed + mainCFrame:VectorToObjectSpace(globalWind).Z)
	local position = mainPart.Position
	local altitude = position.Y
	local bankAngle = -Utils.Deg(Utils.GetRoll(mainCFrame)) + 360
	local invertedBankAngle = Utils.Deg(Utils.GetRoll(mainCFrame * Utils.CFAngles(0, 0, Utils.Pi))) - 360
	local pitchRad, yawAngle, _ = mainCFrame:ToEulerAnglesYXZ()
	local pitchAngle = Utils.Deg(pitchRad)
	
	local lift = if trueSpeed >= _stallSpeed then 1 else 0
	local stalling = if stateWrapper:GetAttribute("Stalling") == true then 1 else 0

	-- Only run physics if the aircraft is unanchored.
	if not mainPart:IsGrounded() then
		--------------------------- Variables ---------------------------
		local _acceleration = Settings.AircraftStatistics.Acceleration * physicsScale
		local _minSpeed = System.MinSpeed * physicsScale
		local _maxSpeed = Utils.Max(Settings.AircraftStatistics.MaxSpeed * physicsScale, 0.001)
		local _angleOfAttack = Settings.AircraftStatistics.AngleOfAttack
		local _flareRate = Utils.Max(Settings.AircraftStatistics.FlareRate * physicsScale, 0.001)
		local _noseLiftFactor = Utils.Clamp(Settings.AircraftStatistics.NoseLiftFactor, 0, 1)
		local _restingAngle = Settings.AircraftStatistics.RestingAngle
		local _tailLift = Settings.AircraftStatistics.TailLift == true
		local _advanced = Settings.AttitudeControls.Advanced
		local _turnSensitivity = Settings.AttitudeControls.TurnSensitivity
		local _lowestPoint = Settings.Advanced.LowestPoint or "Auto"
		------------------------------------------------------------------
		local mass = mainPart.AssemblyMass
		-----------------------------------------
		local lowestPoint = 0
		local hasCollision = false
		
		if _lowestPoint == "Auto" then
			-- Automatic lowest point calculation based on aircraft's size
			local projectedExtent = (boundSize.Y/2) * math.cos(pitchRad) + (boundSize.Z/2) * Utils.Abs(math.sin(pitchRad))
			lowestPoint = projectedExtent + physicsScale
		else
			-- Manual lowest point overwrite
			lowestPoint = Utils.Abs(_lowestPoint)
		end
		
		state.RayFilter.FilterDescendantsInstances = state.IgnoredObjects
		local onGround = workspace:Raycast(position, Utils.V3New(0, -lowestPoint, 0), state.RayFilter)
		if onGround then
			local instance = onGround.Instance
			local model = instance.Parent -- Check for possible ancestor model
			if model:IsA("Model") then -- Model
				local humanoid = model:FindFirstChildOfClass("Humanoid")
				if humanoid == nil then
					hasCollision = Utils.CheckPartCollision(instance, state.IgnoredObjects)
				else -- Exclude player/NPC character if humanoid is detected
					table.insert(state.IgnoredObjects, model)
				end
			else -- Part
				hasCollision = Utils.CheckPartCollision(instance, state.IgnoredObjects)
			end
		else
			-- Reset filter
			if #state.IgnoredObjects > 1 then
				table.clear(state.IgnoredObjects)
				table.insert(state.IgnoredObjects, aircraft)
			end
		end

		if hasCollision then
			local surfaceBankAngle = Utils.GetSurfaceBankAngle(mainPart, onGround.Normal)
			System.CurrentRoll = Utils.Lerp(System.CurrentRoll, surfaceBankAngle, dt)
			
			local relativeCFrame = Utils.GetAlignmentCFrame(mainPart, onGround.Normal)
			local relativePitchAngle = Utils.Deg(Utils.GetPitch(relativeCFrame))

			if _restingAngle ~= "Auto" then
				System.RestingAngle = _restingAngle
			elseif _restingAngle == "Auto" and trueSpeed < physicsScale then
				System.RestingAngle = math.floor(relativePitchAngle * 1000)/1000
			end
		else
			System.CurrentRoll = Utils.Lerp(System.CurrentRoll, Utils.Rad(bankAngle), dt)
		end

		local throttleExponential = if Settings.FlightControls.ThrottleExponential then Utils.Max(System.Throttle, 0.5) else 1
		local desiredSpeed = _maxSpeed * System.Throttle * throttleExponential
		local change = if System.Speed < desiredSpeed + System.MinSpeed then 1 else -1
		local damping = Utils.Clamp(Utils.Abs(System.Speed - desiredSpeed), 0, 1)
		System.Speed = Utils.Clamp(
			System.Speed + (change * damping * _acceleration * dt * 30) - pitchAngle/1000 + System.Boost*physicsScale,
			
			if System.Speed < 0 then
				(if _minSpeed ~= 0 then _minSpeed else -_maxSpeed)
				else
				(if System.Speed < _minSpeed then 0 else _minSpeed),
			
			_maxSpeed)
		
		stalling = if hasCollision then 0 else 1 - lift
		local restingAngle = System.RestingAngle
		local totalLiftForce = lift + stalling
		local liftThreshold = if _noseLiftFactor > 0 then _stallSpeed * Utils.Clamp(1 - _noseLiftFactor - 0.1, 0, 1) else _stallSpeed
		local totalLiftTorque = if trueSpeed >= liftThreshold then 1 else stalling
		------------------------------------------------------------------
		local maxForce = mass * 5e2
		local maxTorque = mass * 5e4
		------------------------------------------------------------------
		local move = if Utils.Abs(System.Speed) >= physicsScale then 1 else 0
		local motionEnabled = motion:GetAttribute("Enabled")
		thrust.MaxAxesForce = Utils.V3New(maxForce * move, maxForce * totalLiftForce, maxForce * move)
		motion.MaxTorque = if motionEnabled == true then Utils.V3New(maxTorque * totalLiftTorque, maxTorque * move, maxTorque * totalLiftTorque) else Utils.V3Zero

		motion.P = Settings.AttitudeControls.TorqueResponsiveness
		motion.D = Settings.AttitudeControls.TorqueResponsiveness/2
		------------------------------------------------------------------

		local altitudeOvershoot = Utils.Min(Utils.Max(altitude - _maxAltitude, 0)/(_maxAltitude*0.1), 1)
		local liftUnderMaxAlt = 1 - altitudeOvershoot
		local gravitySpeed = Utils.V3New(0, -_maxSpeed/2 * (Utils.Max((stalling * liftUnderMaxAlt) - Utils.Min(trueSpeed/_stallSpeed, 1), 0) + altitudeOvershoot), 0) 
		local crosswind = globalWind * Utils.Min(Utils.Max(trueSpeed - _stallSpeed*0.9, 0)/(_stallSpeed*0.1), 1)

		local flareRate = 1 - Utils.Min(Utils.Max(trueSpeed - _stallSpeed, 0)/_flareRate, 1)
		local angleOfAttack = (Utils.CFAngles(0, yawAngle, 0) * Utils.CFAngles(Utils.Rad(_angleOfAttack * flareRate), 0, 0)).LookVector * Utils.V3New(0, 1, 0)
		local lookVector = (mainCFrame.LookVector + angleOfAttack).Unit * Utils.V3New(1, liftUnderMaxAlt, 1)
		local realSpeed = (lookVector * System.Speed) + gravitySpeed + crosswind
		thrust.VectorVelocity = realSpeed
		------------------------------------------------------------------

		local dive = 1 - Utils.Max(Utils.Abs(pitchAngle) - 60, 0)/30
		local stallSpeed95 = _stallSpeed * 0.95 -- 95% of stall speed, aircraft pitches 5% before takeoff.
		local underSpeed = trueSpeed < stallSpeed95 and stalling == 0
		local liftTransition = if _noseLiftFactor > 0 then
			Utils.Min(Utils.Max(trueSpeed - stallSpeed95*(1 - _noseLiftFactor), 0)/(stallSpeed95*_noseLiftFactor), 1)
			else
			if trueSpeed >= stallSpeed95 then 1 else 0
		local groundBlend = 1 - liftTransition
		local tailLiftAngle = if _tailLift then
			restingAngle * groundBlend
			else
			restingAngle
		System.CurrentRoll = Utils.Rad(bankAngle)
		local currentRollCF = Utils.CFAngles(0, 0, System.CurrentRoll)
		if _tailLift then
			-- Always set the current pitch to 0 for taildragger effect.
			System.CurrentPitch = 0
		elseif totalLiftForce == 1 or change > 0 then
			-- Get the current pitch during lift or stall.
			System.CurrentPitch = pitchRad
		end
		
		if _advanced then
			local bankTurn = if bankAngle < 90 and bankAngle > -90 then bankAngle/90 else invertedBankAngle/90
			local turnDecay = Utils.Clamp(trueSpeed/(600 * physicsScale), 0, 0.7)
			local turn = bankTurn * turnDecay * dive
			------------------------------------------------------------------
			local advTurnSensitivity = 1 - Utils.Exp(-_turnSensitivity/0.001 * dt)
			local rollOutput = Utils.Rad(System.Roll * Settings.AttitudeControls.RollSpeed/10 * totalLiftForce) * advTurnSensitivity
			local pitchOutput = Utils.Rad(System.Pitch * Settings.AttitudeControls.PitchSpeed/10 * totalLiftForce) * advTurnSensitivity
			local yawOutput = Utils.Rad(Utils.Clamp((System.Roll * (1 - lift)) + (System.Yaw * (1 - lift/1.5)), -1, 1) * Settings.AttitudeControls.YawSpeed/10 + turn) * advTurnSensitivity

			if underSpeed and hasCollision then
				local _, currentYaw, _ = System.MotionCFrame:ToEulerAnglesYXZ()
				local direction = Utils.CFAngles(0, currentYaw, 0) * Utils.CFAngles(System.CurrentPitch, 0, 0) * currentRollCF
				direction = direction * Utils.CFAngles(0, yawOutput, 0) -- Apply yaw output
				local surfaceUp = onGround.Normal
				
				local directionVector = direction.LookVector
				local flatForward = Utils.V3New(directionVector.X, 0, directionVector.Z).Unit
				local yawOnlyDir = Utils.CFLookAt(position, position + flatForward)

				local groundAlignedWithYaw = yawOnlyDir * Utils.CFAngles(Utils.Rad(tailLiftAngle), 0, 0) * currentRollCF
				local blendAlpha = if change <= 0 or _tailLift then 1 else dt
				
				System.MotionCFrame = direction:Lerp(groundAlignedWithYaw, groundBlend * blendAlpha)
			else
				System.MotionCFrame *= Utils.CFAngles(pitchOutput, yawOutput, rollOutput)
			end
			
			System.Direction = position + (mainCFrame.LookVector * 1e6)
		else
			local nosePosition = position + (mainCFrame.LookVector * 1e6)
			local mouseDir = ((System.MousePosition or nosePosition) - position).Unit
			local turnDecay = 2 - Utils.Clamp(trueSpeed/_maxSpeed, 0, 1)
			local turnSensitivity = _turnSensitivity * turnDecay
			local alpha = 1 - Utils.Exp(-turnSensitivity * dt)

			local yTorque = Utils.V3New(1, totalLiftForce, 1)
			local yRest = Utils.V3New(0, nosePosition.Unit.Y * (1 - totalLiftForce), 0)

			System.Direction = System.Direction:Lerp((mouseDir * yTorque) + yRest, alpha).Unit

			local targetPosition = position + (System.Direction * 1e6)
			local direction = Utils.CFLookAt(position, targetPosition)
			
			local flatMask = Utils.V3New(1, 0, 1)
			local start2D = nosePosition * flatMask
			local target2D = targetPosition * flatMask
						
			if start2D.Magnitude > 0.001 and target2D.Magnitude > 0.001 then
				local angle = math.acos(Utils.Clamp(start2D.Unit:Dot(target2D.Unit), -1, 1))
				local sign = Utils.Sign(Vector3.yAxis:Dot(start2D:Cross(target2D)))
				
				local maxAngle = Utils.Pi/2
				local rollSensitivity = 6 * (1 - Utils.Clamp(_turnSensitivity, 0, 1)/2)
				local rollAlpha = 1 - Utils.Exp(-_turnSensitivity^1.4 * 10 * dt)
				
				System.RollAccumulated = Utils.Lerp(System.RollAccumulated, Utils.Clamp(angle * sign * dive * rollSensitivity, -maxAngle, maxAngle) * totalLiftForce, rollAlpha)
			end
			
			if underSpeed and hasCollision then
				local surfaceUp = onGround.Normal
				local flatForward = Utils.V3New(System.Direction.X, 0, System.Direction.Z).Unit
				local yawOnlyDir = Utils.CFLookAt(position, position + flatForward)

				local groundAlignedWithYaw = CFrame.fromMatrix(
					position,
					yawOnlyDir.RightVector,
					surfaceUp
				) * Utils.CFAngles(Utils.Rad(tailLiftAngle), 0, 0)
				
				direction = direction * currentRollCF
				System.MotionCFrame = direction:Lerp(groundAlignedWithYaw, groundBlend)
			else
				local roll = Utils.CFAngles(0, 0, System.RollAccumulated)
				System.MotionCFrame = direction * roll
			end
		end

		motion.CFrame = System.MotionCFrame

		gravity.Force = Utils.V3New(0, mass * Utils.Max(globalGravity - 35, 0) * Utils.Min(Utils.Abs(System.Speed)/(physicsScale * 3), 1), 0)

		--- Debug for modding ---
		if not thrust.Enabled then
			realSpeed = mainPart.AssemblyLinearVelocity
			System.Speed = -mainCFrame:VectorToObjectSpace(realSpeed).Z
			thrust.VectorVelocity = realSpeed
		end
		if move == 0 or motionEnabled == false then
			System.MotionCFrame = mainCFrame
			motion.CFrame = System.MotionCFrame
			System.RollAccumulated = Utils.Rad(bankAngle)
			System.Direction = mainCFrame.LookVector * 1e6
		end
	else
		-- Don't run physics if anchored.
		local realSpeed = mainPart.AssemblyLinearVelocity
		System.Speed = -mainCFrame:VectorToObjectSpace(realSpeed).Z
		thrust.VectorVelocity = realSpeed
		System.MotionCFrame = mainCFrame
		motion.CFrame = System.MotionCFrame
		System.RollAccumulated = Utils.Rad(bankAngle)
		System.Direction = mainCFrame.LookVector * 1e6
	end

	--- Classic CM32 booleans ---
	if state.Step >= 0.5 then
		local belowMaxAlt = altitude <= _maxAltitude

		stateWrapper:SetAttribute("Taxiing", lift == 0 and stalling == 0)
		stateWrapper:SetAttribute("Flying", lift > 0 and stalling == 0 and belowMaxAlt)
		stateWrapper:SetAttribute("Stalling", stalling == 1 or not belowMaxAlt)

		if onClient then
			local attributes = stateWrapper:GetAttributes()
			local packet = {}
			packet.Taxiing = attributes.Taxiing
			packet.Flying = attributes.Flying
			packet.Stalling = attributes.Stalling

			stateUpdateEvent:FireServer("States", packet)
		end

		state.Step -= 0.5
	end
end

function aeroMini:Cleanup(aircraft)
	local state = self.States[aircraft]

	for i, connection in pairs(state.Connections) do
		connection:Disconnect()
	end
	state.Connections = nil

	self.States[aircraft] = nil
end

return aeroMini]]></ProtectedString>
