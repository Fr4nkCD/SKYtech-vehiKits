										<bool name="DefinesCapabilities">true</bool>
										<string name="Name">Controller</string>
										<int64 name="SourceAssetId">-1</int64>
										<BinaryString name="Tags"></BinaryString>
									</Properties>
								</Item>
							</Item>
						</Item>
					</Item>
				</Item>
				<Item class="Script" referent="RBX5E0C3F9F8FA84309BDF97A7C9394795D">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--[ SKYtech aeroMini ]--

local Settings = {

	AircraftStatistics = {
		Acceleration = 0.25,
		MaxSpeed = 300,
		StallSpeed = 100, -- Minimum speed needed for takeoff
		AngleOfAttack = -5, -- Flare pitch angle in degrees
		FlareRate = 90, -- How much speed it takes to stop flaring.
		NoseLiftFactor = 0.2, --[[ Between 0-1, the duration in percent of the stall speed for
		the nose/tail pitch transition during takeoff/landing. Higher number = longer transition	]]
		TailLift = false, -- Enable nose/tail lift. Useful for taildragger effect.
		RestingAngle = "Auto", --[[	A pitch angle where the aircraft rests on idle (dropping the nose/tail).
		* "Auto" = Automatically finds a resting angle at the idle state (changes dynamically)
		* Degree number = Set to a specific pitch angle in degrees based on the X orientation of the main part on a flat ground)	]]
		MaxAltitude = 10000,
	},
	
	FuelSystem = {
		Enabled = true,
		Consumption = 0.025, -- Percent per second
	},
	
	AttitudeControls = {
		Advanced = false, --[[
		* true = Full controls, allow the aircraft to roll and loop
		* false = Limited flight controls, good for beginners	]]
		RollSpeed = 10,
		PitchSpeed = 5,
		YawSpeed = 5,
		----------------------------------
		TurnSensitivity = 0.5, -- Between 0-1, how sensitive the turning is.
		TorqueResponsiveness = 100,
		-- How sensitive the control responses. Large number = stiffer and less wobbly
	},
	
	-- A custom control script can be added into the loader, ignoring default below.
	FlightControls = {
		CameraType = "Attach",
		--( "Custom", "Scriptable", "Attach", "Follow", "Track", "Orbital", "Fixed", "Watch" )--
		CursorIcon = "rbxassetid://105110588062984", -- Leave a blank quote ("") if not needed.
		ToggleControl = Enum.KeyCode.C, -- Set "nil" (with quotation marks) if you want to force the controls on.
		Engine = Enum.KeyCode.E, -- Set "nil" (with quotation marks) if you have a custom startup script.
		ThrottleUp = Enum.KeyCode.W,
		ThrottleDown = Enum.KeyCode.S,
		ThrottleIncrement = 0.5,
		ThrottleExponential = true, -- If true, speed will not be linearly based on throttle percent.
		LandingGear = Enum.KeyCode.G, -- Set "nil" (with quotation marks) to disable.
		
		-- Non-advanced configuration for mobile (if have)
		MobileRange = Vector2.new(45, 45), -- (Horizontal, Vertical), 0-90 degrees
		
		-- Gamepad/console controls (if have)
		Gamepad = {
			LockCamera = Enum.KeyCode.ButtonL3, --[[ Set "nil" (with quotation marks) if you want to force the camera locked.
			The locked camera type depends on the "CameraType" above.	]]
			Engine = Enum.KeyCode.ButtonY, -- Set "nil" (with quotation marks) if you have a custom startup script.
			ThrottleUp = Enum.KeyCode.ButtonA, -- If it's the ButtonA, the mod has a special function to make it work.
			ThrottleDown = Enum.KeyCode.ButtonB,
			LandingGear = Enum.KeyCode.DPadDown,
		},
		GamepadCameraCycles = {1.5, 1, 0.65, 0}, -- Fartest to closest camera distance scales based on the aircraft's size.
	},
	
	Modifications = { -- Your custom settings here
		--[[ Some modification scripts use attributes here, feel free to edit or remove them.
		Scripts are in the "Mods" folder inside the "Main" section.		]]
		GroupLock = false,
		GroupID = 0,
		GroupRank = 10, -- Minimum rank that can access the aircraft
	},
	
	Advanced = {
		PhysicsScale = 1, -- Physics multiplier (max speed, acceleration, etc)
		ClientControlled = true, -- Pilot takes network ownership by default, allowing instantaneous response.
		ResetNetwork = true, -- Reset network ownership when the pilot exits, otherwise remain with the previous pilot.
		LowestPoint = "Auto" --[[ The aircraft's lowest point for ground detection (stalling and landing gear).
		* "Auto" = Automatically finds the lowest point based on the aircraft's size	
		* Negative number = Manaully sets the specific lowest point in studs (PhysicsScale not applied)		]]
	},

}

--[[ This transforms a settings table into attributes so they can be modfied in game.
* DO NOT EDIT BELOW UNLESS YOU KNOW WHAT YOU ARE DOING * ]]
local configuration = Instance.new("Configuration")
configuration.Name = "Settings"
for i, c in pairs(Settings) do
	for n, v in pairs(c) do
		if typeof(v) == "EnumItem" then -- KeyCode
			configuration:SetAttribute(i.."/"..n, v.Name)
		elseif typeof(v) == "table" then
			for j, k in pairs(v) do
				if typeof(k) == "EnumItem" then -- KeyCode
					configuration:SetAttribute(i.."/"..n.."/"..j, k.Name)
				else
					configuration:SetAttribute(i.."/"..n.."/"..j, k)
				end
			end
		else
			configuration:SetAttribute(i.."/"..n, v)
		end
	end
end

local vehicle = script.Parent
configuration.Parent = vehicle
vehicle:AddTag("SKYtech aeroMini") -- Tag is mandatory for the system to load.

--require(100312192466174) -- Load the source module from cloud.]]></ProtectedString>
